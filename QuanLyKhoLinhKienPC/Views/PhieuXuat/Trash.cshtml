@model IEnumerable<QuanLyKhoLinhKienPC.Models.PhieuXuat>

@{
    ViewData["Title"] = "Thùng Rác Hóa Đơn Bán";
}

<div class="container-fluid pt-4 h-100 overflow-y-auto">
    <div class="row mb-3 align-items-center">
        <div class="col-md-6">
            <h3 class="text-secondary fw-bold"><i class="fa-solid fa-trash-can"></i> Hóa Đơn Đã Hủy / Khách Trả Hàng</h3>
        </div>
        <div class="col-md-6 text-end">
            @if (User.IsInRole("Quản trị viên") || User.IsInRole("Admin"))
            {

            }
            <a asp-action="Index" class="btn btn-secondary shadow-sm fw-bold ms-2">
                <i class="fa-solid fa-arrow-left"></i> Quay lại
            </a>
        </div>
    </div>


    <div class="card shadow-sm flex-grow-1 overflow-hidden border-0">
        <div class="card-body p-0 position-relative">
            <div class="table-responsive" style="position: absolute; top: 0; bottom: 0; left: 0; right: 0;">
                <table class="table table-hover align-middle mb-0 w-100">
                    <thead class="table-secondary text-center">
                        <tr>
                            <th class="py-3 text-center" style="width: 5%; position: sticky; top: 0; z-index: 10;">STT</th>
                            <th class="py-3 ps-4 text-start" style="position: sticky; top: 0; z-index: 10;">Mã Phiếu Xuất</th>
                            <th class="py-3" style="position: sticky; top: 0; z-index: 10;">Ngày Hủy Yêu Cầu</th>
                            <th class="py-3" style="position: sticky; top: 0; z-index: 10;">Khách Hàng</th>
                            <th class="py-3" style="position: sticky; top: 0; z-index: 10;">Người Lập Phiếu</th>
                            <th class="py-3 text-end" style="position: sticky; top: 0; z-index: 10;">Tiền Khách Trả (VNĐ)</th>
                            <th class="py-3 text-center pe-4" style="position: sticky; top: 0; z-index: 10;">Thao Tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted py-5">
                                    <i class="fa-regular fa-trash-can fa-3x mb-3 text-secondary opacity-50"></i><br>
                                    Thùng rác trống.
                                </td>
                            </tr>
                        }
                        else
                        {
                            int stt = 1;
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="text-center text-muted fw-bold">@(stt++)</td>
                                    <td class="ps-4 fw-bold text-secondary">
                                        #PX-@item.MaPhieuXuat.ToString("D5")
                                    </td>
                                    <td class="text-center">
                                        <span class="badge bg-light text-dark border">
                                            <i class="fa-regular fa-calendar"></i> @item.NgayXuat.ToString("dd/MM/yyyy HH:mm")
                                        </span>
                                    </td>
                                    <td class="text-center fw-bold text-muted">
                                        <del>@item.TenKhachHang</del>
                                    </td>
                                    <td class="text-center text-muted">
                                        <i class="fa-solid fa-user-pen text-muted"></i> @(item.MaNguoiDungNavigation?.HoTen ?? "Hệ thống")
                                    </td>
                                    <td class="text-end fw-bold text-muted">
                                        <del>@string.Format("{0:N0}", item.TongTien) đ</del>
                                    </td>
                                    <td class="text-center pe-4">
                                        <form asp-action="Restore" asp-route-id="@item.MaPhieuXuat" method="post" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-success shadow-sm text-white" title="Khôi phục lại hóa đơn và rút lại hàng trong kho">
                                                <i class="fa-solid fa-trash-arrow-up"></i> Khôi Phục
                                            </button>
                                        </form>

                                        @if (User.IsInRole("Quản trị viên") || User.IsInRole("Admin"))
                                        {

                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
