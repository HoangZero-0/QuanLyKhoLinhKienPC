@model QuanLyKhoLinhKienPC.Models.PhieuXuat
@using System.Linq

@{
    ViewData["Title"] = "Chi Tiết Hóa Đơn Bán Lẻ";
    // Thuật toán: Vì ChiTietPhieuXuat lưu theo Từng Thẻ Seri Đơn Lẻ (Tức là mua 5 cái RAM thì có 5 dòng seri ghim vào)
    // -> Cần Group By lại MaSanPham để in ra Bill thu gọn (Chỉ lặp 1 dòng Tên RAM, Cột Số Lượng = 5) thay vì In dài ngoằng 5 dòng.
    
    var listGomNhom = Model.ChiTietPhieuXuat
        .GroupBy(ct => new { 
            IdSP = ct.MaSeriNavigation?.MaSanPham, 
            TenSP = ct.MaSeriNavigation?.MaSanPhamNavigation?.TenSanPham,
            GiaXuat = ct.GiaTien
        })
        .Select(g => new {
            IdSP = g.Key.IdSP,
            TenSP = g.Key.TenSP,
            DonGia = g.Key.GiaXuat,
            SoLuongBan = g.Count(),
            ThanhTienBan = g.Count() * g.Key.GiaXuat,
            MaCácSeri = string.Join(", ", g.Select(x => x.MaSeriNavigation?.SoSeri)) 
        }).ToList();
}

<div class="container-fluid pt-4 pb-5 px-sm-4 bg-light">
    <!-- HEADER HÀNH ĐỘNG (Không hiển thị khi in) -->
    <div class="d-flex justify-content-between align-items-center mb-4 no-print mx-auto" style="max-width: 900px;">
        <h2 class="text-success m-0"><i class="fa-solid fa-file-invoice-dollar me-1"></i> Chi Tiết Hóa Đơn Bán</h2>
        <div class="d-flex gap-2">
            <button onclick="window.print()" class="btn btn-dark shadow-sm rounded-pill px-4 fw-bold transition">
                <i class="fa-solid fa-print me-1"></i> In hóa đơn
            </button>
            <a asp-action="Index" class="btn btn-light border shadow-sm rounded-pill px-4 fw-semibold text-secondary transition">
                <i class="fa-solid fa-arrow-left me-1"></i> Quay lại
            </a>
        </div>
    </div>

    <!-- KHUNG HÓA ĐƠN A4 -->
    <div class="invoice-container bg-white mx-auto p-4 p-md-5" style="max-width: 900px;">
        <!-- Phần Header Cửa hàng -->
        <div class="row border-bottom border-2 border-success pb-3 mb-4 align-items-center">
            <div class="col-sm-6 text-center text-sm-start mb-3 mb-sm-0">
                <h5 class="fw-bold mb-1 text-uppercase text-success">Cửa Hàng Linh Kiện PC</h5>
                <p class="mb-0 small">Địa chỉ: Long Xuyên, An Giang</p>
                <p class="mb-0 small">Điện thoại: 0123 456 789</p>
            </div>
            <div class="col-sm-6 text-center text-sm-end">
                <h5 class="fw-bold mb-1 text-uppercase">Hóa Đơn Bán Hàng</h5>
                <p class="mb-0 small">Mã số: <strong>#PX-@Model.MaPhieuXuat.ToString("D5")</strong></p>
                <p class="mb-0 small">Ngày lập: @Model.NgayXuat.ToString("dd/MM/yyyy HH:mm")</p>
            </div>
        </div>

        <!-- Thông tin Đối tác / Giao dịch -->
        <div class="row mb-4">
            <div class="col-12">
                <table class="table table-sm table-borderless mb-0">
                    <tbody>
                        <tr>
                            <td class="fw-semibold" style="width: 150px;">Khách hàng:</td>
                            <td class="text-uppercase fw-bold text-success fs-5">@Model.TenKhachHang</td>
                        </tr>
                        <tr>
                            <td class="fw-semibold">Số điện thoại:</td>
                            <td>@(string.IsNullOrEmpty(Model.SoDienThoaiKhach) ? "---" : Model.SoDienThoaiKhach)</td>
                        </tr>
                        <tr>
                            <td class="fw-semibold">Thu ngân viên:</td>
                            <td>@(Model.MaNguoiDungNavigation?.HoTen ?? "Hệ thống")</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Bảng Chi tiết Linh Kiện -->
        <div class="table-responsive mb-3">
            <table class="table table-bordered border-dark align-middle mb-0">
                <thead class="text-center fw-bold" style="background-color: #f8f9fa !important; -webkit-print-color-adjust: exact; print-color-adjust: exact;">
                    <tr>
                        <th style="width: 5%;">STT</th>
                        <th style="width: 40%;">Cấu Hình Tuyến Kênh (Linh Kiện)</th>
                        <th style="width: 8%;">ĐVT</th>
                        <th style="width: 12%;">SL</th>
                        <th style="width: 15%;">Đơn Giá (VNĐ)</th>
                        <th style="width: 20%;">Thành Tiền (VNĐ)</th>
                    </tr>
                </thead>
                <tbody>
                    @if (listGomNhom == null || !listGomNhom.Any())
                    {
                        <tr><td colspan="6" class="text-center text-muted fst-italic py-3 border-dark">Không có thông tin linh kiện.</td></tr>
                    }
                    else
                    {
                        int stt = 1;
                        @foreach (var ct in listGomNhom)
                        {
                            <tr class="border-dark">
                                <td class="text-center fw-medium border-dark">@(stt++)</td>
                                <td class="fw-semibold text-dark border-dark">
                                    @ct.TenSP
                                    <div class="small fw-normal text-secondary fst-italic mt-1" style="font-size: 0.8rem; line-height: 1.2;">
                                        <i class="fa-solid fa-barcode"></i> Mã Bảo Hành (SN): @ct.MaCácSeri
                                    </div>
                                </td>
                                <td class="text-center border-dark">Cái</td>
                                <td class="text-center fw-bold text-dark border-dark fs-5">@ct.SoLuongBan</td>
                                <td class="text-end fw-medium text-dark border-dark">@ct.DonGia.ToString("N0")</td>
                                <td class="text-end fw-bold text-danger border-dark">@ct.ThanhTienBan.ToString("N0")</td>
                            </tr>
                        }
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="5" class="text-end fw-bold py-3 text-uppercase align-middle border-dark">Tổng Khách Trả:</td>
                        <td class="text-end fw-bold fs-4 py-3 text-danger border-dark">@Model.TongTien.ToString("N0")</td>
                    </tr>
                </tfoot>
            </table>
        </div>

        <!-- Khu vực Chữ ký -->
        <div class="row pt-4 text-center mt-3" style="page-break-inside: avoid;">
            <div class="col-4">
                <p class="fw-bold mb-0">Người Lập Hóa Đơn</p>
                <p class="text-muted small fst-italic mb-5 pb-4">(Ký, ghi rõ họ tên)</p>
            </div>
            <div class="col-4">
            </div>
            <div class="col-4">
                <p class="fw-bold mb-0">Khách Hàng</p>
                <p class="text-muted small fst-italic mb-5 pb-4">(Ký xác nhận nhận hàng)</p>
            </div>
        </div>

        <!-- RECIEPT FOOTER -->
        <div class="text-center text-muted border-top pt-4 mt-5">
            <p class="mb-1 fw-bold fs-5 text-success">Cảm ơn Quý Khách Đã Mua Sắm!</p>
            <small class="fst-italic"><i class="fa-solid fa-gift"></i> Chính sách bảo hành áp dụng đầy đủ theo các mã Seri gốc được in trên phiếu.</small>
        </div>
    </div>
</div>

<link rel="stylesheet" href="~/css/print-invoice.css" />

<style>
    /* CSS cho vùng hiển thị web */
    .transition { transition: all 0.2s ease; }
    .invoice-container {
        box-shadow: 0 0 20px rgba(0, 0, 0, 0.08);
        border: 1px solid #ced4da;
    }
</style>
