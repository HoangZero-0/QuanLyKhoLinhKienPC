@model QuanLyKhoLinhKienPC.Models.PhieuXuat
@using System.Linq

@{
    ViewData["Title"] = "Chi Tiết Hóa Đơn Bán Lẻ";
    // Thuật toán: Vì ChiTietPhieuXuat lưu theo Từng Thẻ Seri Đơn Lẻ (Tức là mua 5 cái RAM thì có 5 dòng seri ghim vào)
    // -> Cần Group By lại MaSanPham để in ra Bill thu gọn (Chỉ lặp 1 dòng Tên RAM, Cột Số Lượng = 5) thay vì In dài ngoằng 5 dòng.
    // Lợi ích: Khách hàng chỉ quan tâm Tên Tống Quát + SL. Không quan tâm mã Seri.

    var listGomNhom = Model.ChiTietPhieuXuat
        .GroupBy(ct => new { 
            IdSP = ct.MaSeriNavigation?.MaSanPham, 
            TenSP = ct.MaSeriNavigation?.MaSanPhamNavigation?.TenSanPham,
            GiaXuat = ct.GiaTien
        })
        .Select(g => new {
            IdSP = g.Key.IdSP,
            TenSP = g.Key.TenSP,
            DonGia = g.Key.GiaXuat,
            SoLuongBan = g.Count(),
            ThanhTienBan = g.Count() * g.Key.GiaXuat,
            // (Thích thì có thể nối chuỗi hiển thị luôn tập hợp mã Seri ra Bill)
            MaCácSeri = string.Join(", ", g.Select(x => x.MaSeriNavigation?.SoSeri)) 
        }).ToList();
}

<div class="container-fluid pt-4">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <!-- PAPER RECEIPT STYLE CARD -->
            <div class="card shadow-lg border-0 mb-4" style="background-color: #fdfdfd; border-top: 5px solid #198754 !important;">
                
                <!-- RECIEPT HEADER -->
                <div class="card-header bg-transparent border-bottom-0 pt-4 pb-2 px-4 px-md-5 d-flex justify-content-between align-items-center">
                    <div>
                        <h2 class="text-success fw-bold mb-1"><i class="fa-solid fa-receipt"></i> HÓA ĐƠN BÁN LẺ</h2>
                        <h5 class="text-muted">Mã chứng từ: <span class="text-dark fw-bold">#PX-@Model.MaPhieuXuat.ToString("D5")</span></h5>
                    </div>
                    <div class="text-end">
                        <img src="/images/logo.png" alt="Logo" style="max-height: 50px; opacity: 0.8" onerror="this.style.display='none'" />
                        <p class="mb-0 fs-6 text-muted">Ngày xuất: @Model.NgayXuat.ToString("dd/MM/yyyy HH:mm")</p>
                    </div>
                </div>

                <div class="card-body px-4 px-md-5 pt-0">
                    <hr class="mb-4" style="border-top: 2px dashed #ccc; opacity: 1;">
                    
                    <!-- MASTER INFO -->
                    <div class="row mb-5">
                        <div class="col-sm-6">
                            <h6 class="text-uppercase text-muted fw-bold mb-2 small"><i class="fa-solid fa-bag-shopping"></i> Thông tin Khách hàng</h6>
                            <div class="p-3 bg-light rounded border border-success border-opacity-25">
                                <h5 class="fw-bold mb-1">Mã KH: @Model.TenKhachHang</h5>
                                <p class="mb-1"><i class="fa-solid fa-phone text-muted"></i> @(string.IsNullOrEmpty(Model.SoDienThoaiKhach) ? "Không lưu số" : Model.SoDienThoaiKhach)</p>
                            </div>
                        </div>
                        <div class="col-sm-6 text-sm-end mt-4 mt-sm-0">
                            <h6 class="text-uppercase text-muted fw-bold mb-2 small"><i class="fa-solid fa-circle-info"></i> Thông tin hệ thống</h6>
                            <p class="mb-1 text-muted">Bill in ấn ngày: <span class="fw-bold text-dark">@DateTime.Now.ToString("dd/MM/yyyy")</span></p>
                            <p class="mb-1 text-muted">Thu ngân viên: <span class="fw-bold text-dark">@(Model.MaNguoiDungNavigation?.HoTen ?? "Hệ thống")</span></p>
                        </div>
                    </div>

                    <!-- DETAILS TABLE (ĐÃ GROUP BY SP THEO YÊU CẦU TRÊN) -->
                    <div class="table-responsive rounded shadow-sm border mb-4">
                        <table class="table table-hover mb-0">
                            <thead class="table-light text-secondary border-bottom">
                                <tr>
                                    <th class="ps-4">STT</th>
                                    <th>Cấu hình Linh Kiện Bán Ra</th>
                                    <th class="text-center">Số Lượng</th>
                                    <th class="text-end">Đơn Giá</th>
                                    <th class="text-end pe-4">Thành Tiền</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (listGomNhom == null || !listGomNhom.Any())
                                {
                                    <tr><td colspan="5" class="text-center text-muted fst-italic py-3">Không có thông tin chi tiết Seri trong cơ sở dữ liệu.</td></tr>
                                }
                                else
                                {
                                    int stt = 1;
                                    foreach (var ct in listGomNhom)
                                    {
                                        <tr>
                                            <td class="ps-4 text-muted pt-3">@stt</td>
                                            <td class="pt-3">
                                                <span class="fw-bold text-success">@ct.TenSP</span>
                                                <div class="small text-muted fst-italic mt-1" style="font-size: 0.8rem; line-height: 1.2;">
                                                    <i class="fa-solid fa-barcode"></i> Mã Bảo Hành: @ct.MaCácSeri
                                                </div>
                                            </td>
                                            <td class="text-center fw-bold pt-3 fs-5">@ct.SoLuongBan</td>
                                            <td class="text-end pt-3">@string.Format("{0:N0}", ct.DonGia) đ</td>
                                            <td class="text-end pe-4 fw-bold pt-3 text-secondary">@string.Format("{0:N0}", ct.ThanhTienBan) đ</td>
                                        </tr>
                                        stt++;
                                    }
                                }
                            </tbody>
                        </table>
                    </div>

                    <!-- TOTALS SUMMARY -->
                    <div class="row justify-content-end mb-4">
                        <div class="col-8 col-sm-6 col-md-5 col-lg-5">
                            <table class="table table-borderless table-sm mb-0">
                                <tbody>
                                    <tr>
                                        <td class="ps-0 pt-2 text-muted fw-bold">Trạng thái: </td>
                                        <td class="text-end pt-2 pe-0"><span class="badge bg-success">Đã Thanh Toán Biên Lai</span></td>
                                    </tr>
                                    <tr class="fs-4 border-top border-2 border-dark">
                                        <td class="fw-bold ps-0 pt-3">TỔNG KHÁCH TRẢ:</td>
                                        <td class="text-end fw-bold text-danger pt-3 pe-0">@string.Format("{0:N0}", Model.TongTien) VNĐ</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- RECIEPT FOOTER -->
                    <div class="text-center text-muted border-top pt-4 mb-2">
                        <p class="mb-1 fw-bold fs-5">Cảm ơn Quý Khách Đã Mua Sắm!</p>
                        <small class="fst-italic"><i class="fa-solid fa-gift"></i> Chính sách bảo hành áp dụng đầy đủ theo các mã Seri gốc được in trên phiếu.</small>
                    </div>
                </div>
            </div>
            
            <!-- ACTION BUTTONS -->
            <div class="d-flex justify-content-between mb-5">
                <a asp-action="Index" class="btn btn-secondary shadow-sm">
                    <i class="fa-solid fa-arrow-left"></i> Trở về Lịch Sử Bán Hàng
                </a>
                <button onclick="window.print()" class="btn btn-success px-4 shadow-sm fw-bold">
                    <i class="fa-solid fa-print"></i> Cắt Hóa Đơn Lẻ (In)
                </button>
            </div>
        </div>
    </div>
</div>

<style>
/* CSS giành riêng cho chức năng IN (Ctrl+P) */
@@media print {
    body * { visibility: hidden; }
    .card, .card * { visibility: visible; }
    .card {
        position: absolute; left: 0; top: 0; width: 100%;
        box-shadow: none !important; border: none !important;
    }
    .btn { display: none !important; }
}
</style>
