@model QuanLyKhoLinhKienPC.ViewModels.PhieuXuatVM
@using System.Text.Json
@{
    ViewData["Title"] = "Lập Phiếu Xuất Kho (Bán Hàng)";
}

@section Styles {
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <style>
        .select2-container--default .select2-selection--multiple {
            border: 1px solid #ced4da;
            min-height: 38px;
        }
        .select2-container {
            width: 100% !important;
        }
    </style>
}

<div class="container-fluid pt-4">
    <div class="row justify-content-center">
        <div class="col-md-11">
            <div class="card shadow mb-4 border-success">
                <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                    <h4 class="mb-0"><i class="fa-solid fa-cart-shopping"></i> Lập Phiếu Xuất Kho</h4>
                    <span class="badge bg-warning text-dark fs-5 shadow-sm">
                        Tổng cộng: <span id="lblTongTien" class="fw-bold fs-4">0</span> VND
                    </span>
                </div>
                
                <div class="card-body">
                    <form asp-action="Create" id="frmPhieuXuat">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger px-3 py-2"></div>
                        
                        <!-- MASTER INFO -->
                        <h5 class="text-success border-bottom border-success pb-2 mb-3"><i class="fa-solid fa-1"></i> Thông Tin Khách Hàng</h5>
                        <div class="row mb-4">
                            <div class="col-md-4 mb-3">
                                <label asp-for="TenKhachHang" class="form-label fw-bold">Tên Khách Hàng <span class="text-danger">*</span></label>
                                <input asp-for="TenKhachHang" class="form-control shadow-sm" placeholder="Nhập tên khách..." required />
                                <span asp-validation-for="TenKhachHang" class="text-danger small"></span>
                            </div>
                            <div class="col-md-3 mb-3">
                                <label asp-for="SoDienThoaiKhach" class="form-label fw-bold">Số Điện Thoại <span class="text-danger">*</span></label>
                                <input asp-for="SoDienThoaiKhach" class="form-control shadow-sm" placeholder="09xxxx..." required />
                                <span asp-validation-for="SoDienThoaiKhach" class="text-danger small"></span>
                            </div>
                            <div class="col-md-5 mb-3">
                                <label asp-for="GhiChu" class="form-label fw-bold">Ghi Chú</label>
                                <input asp-for="GhiChu" class="form-control shadow-sm" placeholder="Ghi chú đơn hàng (nếu có)..." />
                            </div>
                        </div>

                        <!-- DETAILS CAART -->
                        <div class="d-flex justify-content-between align-items-center border-bottom border-success pb-2 mb-3">
                            <h5 class="text-success mb-0"><i class="fa-solid fa-2"></i> Chi Tiết Sản Phẩm & Mã Máy (Seri)</h5>
                            <button type="button" class="btn btn-sm btn-outline-success shadow-sm fw-bold" onclick="themDong()">
                                <i class="fa-solid fa-plus"></i> Thêm Linh Kiện
                            </button>
                        </div>
                        
                        <div class="table-responsive shadow-sm border rounded">
                            <table class="table table-bordered table-hover mb-0" id="tblChiTiet">
                                <thead class="table-success text-center">
                                    <tr>
                                        <th style="width: 25%">Linh Kiện <span class="text-danger">*</span></th>
                                        <th>Chọn Mã Máy (Seri) - Tối đa tồn kho</th>
                                        <th style="width: 10%">Số Lượng</th>
                                        <th style="width: 15%">Đơn Giá Bán</th>
                                        <th style="width: 15%">Thành Tiền</th>
                                        <th style="width: 5%"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <!-- Dòng động JS -->
                                </tbody>
                            </table>
                        </div>

                        <div id="hiddenInputsContainer"></div>

                        <div class="d-flex justify-content-between mt-5 pt-3 border-top">
                            <a asp-action="Index" class="btn btn-secondary shadow-sm">
                                <i class="fa-solid fa-arrow-left"></i> Quay lại
                            </a>
                            <button type="button" class="btn btn-success shadow-sm fw-bold fs-5 px-5" onclick="submitForm()">
                                <i class="fa-solid fa-circle-check"></i> XUẤT KHO & IN HÓA ĐƠN
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    
    <script>
        var dsSanPham = @Html.Raw(Json.Serialize(ViewBag.SanPhamList));
        var chiTietList = [];

        function renderTable() {
            var tbody = $('#tblChiTiet tbody');
            tbody.empty();
            var tongTienPhieu = 0;

            if(chiTietList.length === 0) {
                tbody.append('<tr><td colspan="6" class="text-center text-muted fst-italic py-4">Chưa có linh kiện nào. Bấm "Thêm Linh Kiện" để bắt đầu.</td></tr>');
            } else {
                chiTietList.forEach(function(item, index) {
                    var sanPhamOptions = '<option value="">-- Chọn linh kiện --</option>';
                    dsSanPham.forEach(function(sp) {
                        var kMaSP = sp.MaSanPham || sp.maSanPham;
                        var kTenSP = sp.TenSanPham || sp.tenSanPham;
                        var selected = kMaSP == item.MaSanPham ? 'selected' : '';
                        sanPhamOptions += `<option value="${kMaSP}" ${selected}>${kTenSP}</option>`;
                    });

                    var thanhTien = item.SoLuong * item.DonGiaXuat;
                    tongTienPhieu += thanhTien;

                    var tr = `
                        <tr data-index="${index}">
                            <td>
                                <select class="form-select select-sp" onchange="chonSanPham(${index}, this)">
                                    ${sanPhamOptions}
                                </select>
                            </td>
                            <td>
                                <select class="form-control select-seri" multiple="multiple" onchange="capNhatSeri(${index}, this)">
                                    <!-- Options load qua JS dựa trên linh kiện -->
                                </select>
                            </td>
                            <td>
                                <input type="number" class="form-control text-center fw-bold bg-light" value="${item.SoLuong}" readonly />
                            </td>
                            <td>
                                <input type="number" class="form-control text-end" value="${item.DonGiaXuat}" onchange="capNhatGia(${index}, this)" />
                            </td>
                            <td class="text-end fw-bold text-danger align-middle fs-6">
                                ${new Intl.NumberFormat('vi-VN').format(thanhTien)}
                            </td>
                            <td class="text-center align-middle">
                                <button type="button" class="btn btn-sm btn-link text-danger p-0" onclick="xoaDong(${index})">
                                    <i class="fa-solid fa-circle-xmark fs-4"></i>
                                </button>
                            </td>
                        </tr>
                    `;
                    tbody.append(tr);
                    
                    // Khởi tạo Select2 cho ô Seri của dòng này
                    initSelect2Seri(index);
                });
            }
            $('#lblTongTien').text(new Intl.NumberFormat('vi-VN').format(tongTienPhieu));
        }

        function initSelect2Seri(index) {
            var row = $(`tr[data-index="${index}"]`);
            var selectSeri = row.find('.select-seri');
            var item = chiTietList[index];

            if (!item.MaSanPham) {
                selectSeri.prop('disabled', true);
                return;
            }

            // Lấy danh sách Seri khả dụng của sản phẩm này
            var prod = dsSanPham.find(s => (s.MaSanPham || s.maSanPham) == item.MaSanPham);
            selectSeri.empty();
            if (prod && prod.AvailableSeris) {
                prod.AvailableSeris.forEach(function(seri) {
                    var kMaSeri = seri.MaSeri || seri.maSeri;
                    var kSoSeri = seri.SoSeri || seri.soSeri;
                    var selected = item.SelectedSeriIds.includes(kMaSeri) ? 'selected' : '';
                    selectSeri.append(`<option value="${kMaSeri}" ${selected}>${kSoSeri}</option>`);
                });
            }

            selectSeri.select2({
                placeholder: "-- Chọn mã máy --",
                allowClear: true,
                closeOnSelect: false
            });
        }

        function chonSanPham(index, selectElem) {
            var maSP = $(selectElem).val();
            var prod = dsSanPham.find(s => (s.MaSanPham || s.maSanPham) == maSP);
            
            chiTietList[index].MaSanPham = maSP;
            chiTietList[index].DonGiaXuat = prod ? (prod.GiaBan || prod.giaBan) : 0;
            chiTietList[index].SelectedSeriIds = [];
            chiTietList[index].SoLuong = 0;
            
            renderTable();
        }

        function capNhatSeri(index, selectElem) {
            var selectedIds = $(selectElem).val() || [];
            chiTietList[index].SelectedSeriIds = selectedIds.map(id => parseInt(id));
            chiTietList[index].SoLuong = selectedIds.length;
            renderTable();
        }

        function capNhatGia(index, inputElem) {
            chiTietList[index].DonGiaXuat = parseFloat($(inputElem).val()) || 0;
            renderTable();
        }

        function themDong() {
            chiTietList.push({ MaSanPham: '', SelectedSeriIds: [], SoLuong: 0, DonGiaXuat: 0 });
            renderTable();
        }

        function xoaDong(index) {
            chiTietList.splice(index, 1);
            renderTable();
        }

        function submitForm() {
            if(!$('#TenKhachHang').val() || !$('#SoDienThoaiKhach').val()) {
                Swal.fire('Thiếu thông tin', 'Vui lòng điền đầy đủ Tên và SĐT khách hàng!', 'warning');
                return;
            }
            if(chiTietList.length === 0) {
                Swal.fire('Giỏ hàng trống', 'Vui lòng thêm ít nhất một sản phẩm!', 'warning');
                return;
            }

            var hopLe = true;
            chiTietList.forEach(function(item) {
                if(!item.MaSanPham || item.SoLuong <= 0) hopLe = false;
            });

            if(!hopLe) {
                Swal.fire('Dữ liệu không hợp lệ', 'Mỗi dòng phải chọn ít nhất 1 mã máy (Seri).', 'error');
                return;
            }

            var hiddenContainer = $('#hiddenInputsContainer');
            hiddenContainer.empty();
            
            chiTietList.forEach(function(item, index) {
                hiddenContainer.append(`<input type="hidden" name="Items[${index}].MaSanPham" value="${item.MaSanPham}" />`);
                hiddenContainer.append(`<input type="hidden" name="Items[${index}].DonGiaXuat" value="${item.DonGiaXuat}" />`);
                item.SelectedSeriIds.forEach(function(seriId, sIdx) {
                    hiddenContainer.append(`<input type="hidden" name="Items[${index}].SelectedSeriIds[${sIdx}]" value="${seriId}" />`);
                });
            });

            $('#frmPhieuXuat').submit();
        }

        $(document).ready(function() {
            renderTable();
        });
    </script>
}
