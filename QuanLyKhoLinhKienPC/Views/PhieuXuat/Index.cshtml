@model IEnumerable<QuanLyKhoLinhKienPC.Models.PhieuXuat>

@{
    ViewData["Title"] = "Lịch Sử Phiếu Xuất Bán Hàng";
}

<div class="container-fluid pt-4">
    <div class="row mb-3 align-items-center">
        <div class="col-md-6">
            <h3 class="text-success fw-bold"><i class="fa-solid fa-clock-rotate-left"></i> Lịch Sử Phiếu Xuất (Bán Hàng)</h3>
        </div>
        <div class="col-md-6 text-end">
            <a asp-action="Create" class="btn btn-success shadow-sm fw-bold">
                <i class="fa-solid fa-cart-arrow-down"></i> Lập Hóa Đơn Bán Mới
            </a>
            <a asp-action="Trash" class="btn btn-secondary shadow-sm fw-bold ms-2">
                <i class="fa-solid fa-trash-can"></i> Đơn Đã Hủy / Khách Trả Hàng
            </a>
        </div>
    </div>

    <!-- Cảnh báo Mềm khi hoàn thành Tạo Hóa đơn từ Create đổ về -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success mt-2">@TempData["Success"]</div>
    }

    <div class="card shadow border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-success text-center">
                        <tr>
                            <th class="ps-4 text-start">Mã Phiếu Xuất</th>
                            <th>Ngày Bán</th>
                            <th>Khách Hàng</th>
                            <th>Người Lập Phiếu</th>
                            <th class="text-end">Tiền Khách Trả (VNĐ)</th>
                            <th class="text-center pe-4">Thao Tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted fst-italic py-4">Chưa có Giấy Giao nhận/Hóa Đơn nào được lập.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold text-success">
                                        #PX-@item.MaPhieuXuat.ToString("D5")
                                    </td>
                                    <td class="text-center">
                                        <span class="badge bg-light text-dark border">
                                            <i class="fa-regular fa-calendar"></i> @item.NgayXuat.ToString("dd/MM/yyyy HH:mm")
                                        </span>
                                    </td>
                                    <td class="text-center fw-bold">
                                        @item.TenKhachHang
                                        @if (!string.IsNullOrEmpty(item.SoDienThoaiKhach))
                                        {
                                            <br/><small class="fw-normal text-muted"><i class="fa-solid fa-phone"></i> @item.SoDienThoaiKhach</small>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <i class="fa-solid fa-user-pen text-muted"></i> @(item.MaNguoiDungNavigation?.HoTen ?? "Hệ thống")
                                    </td>
                                    <td class="text-end fw-bold text-danger">
                                        @string.Format("{0:N0}", item.TongTien) đ
                                    </td>
                                    <td class="text-center pe-4">
                                        <a asp-action="Details" asp-route-id="@item.MaPhieuXuat" class="btn btn-sm btn-info text-white shadow-sm" title="Xem Hóa Đơn">
                                            <i class="fa-solid fa-print"></i> Biên Lai
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.MaPhieuXuat" class="btn btn-sm btn-danger text-white shadow-sm ms-1" title="Hủy Phiếu / Khách Trả Hàng">
                                            <i class="fa-solid fa-rotate-left"></i> Trả Hàng
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
