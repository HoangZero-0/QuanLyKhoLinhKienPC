@model IEnumerable<QuanLyKhoLinhKienPC.Models.PhieuXuat>

@{
    ViewData["Title"] = "Lịch Sử Phiếu Xuất Bán Hàng";
}

<div class="d-flex flex-column h-100">
    <div class="d-flex justify-content-between align-items-center mb-3 flex-shrink-0">
        <h2 class="text-success m-0"><i class="fa-solid fa-clock-rotate-left"></i> Lịch Sử Phiếu Xuất (Bán Hàng)</h2>
        @if (User.IsInRole("Quản trị viên") || User.IsInRole("Admin") || User.IsInRole("Nhân viên bán hàng"))
        {
            <div>
                <a asp-action="Create" class="btn btn-success shadow-sm fw-bold">
                    <i class="fa-solid fa-cart-arrow-down"></i> Lập Hóa Đơn Bán Mới
                </a>
                <a asp-action="Trash" class="btn btn-light border shadow-sm rounded-pill px-3 transition text-danger" title="Thùng rác / Đơn hủy">
                    <i class="fa-solid fa-trash-can"></i>
                </a>
            </div>
        }
    </div>


    <div class="card shadow-sm flex-grow-1 overflow-hidden border-0">
        <div class="card-body p-0 position-relative">
            <div class="table-responsive" style="position: absolute; top: 0; bottom: 0; left: 0; right: 0;">
                <table class="table table-striped table-hover mb-0 w-100 align-middle">
                    <thead class="table-success text-center">
                        <tr>
                            <th class="py-3 text-center" style="width: 5%; position: sticky; top: 0; z-index: 10;">STT</th>
                            <th class="py-3 ps-4 text-start" style="position: sticky; top: 0; z-index: 10;">Mã Phiếu Xuất</th>
                            <th class="py-3" style="position: sticky; top: 0; z-index: 10;">Ngày Bán</th>
                            <th class="py-3" style="position: sticky; top: 0; z-index: 10;">Khách Hàng</th>
                            <th class="py-3" style="position: sticky; top: 0; z-index: 10;">Người Lập Phiếu</th>
                            <th class="py-3 text-end" style="position: sticky; top: 0; z-index: 10;">Tiền Khách Trả (VNĐ)</th>
                            <th class="py-3 text-center pe-4" style="position: sticky; top: 0; z-index: 10;">Thao Tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <style>
                                .empty-state-row { height: 350px; }
                                @@media (min-height: 800px) { .empty-state-row { height: 450px; } }
                            </style>
                            <tr class="empty-state-row">
                                <td colspan="7" class="text-center text-muted align-middle border-0">
                                    <div class="py-5">
                                        <i class="fa-solid fa-file-invoice-dollar fa-4x mb-4 text-secondary opacity-25 d-block"></i>
                                        <p class="fs-4 fw-medium mb-1">Không tìm thấy dữ liệu nào</p>
                                    </div>
                                </td>
                            </tr>
                        }
                        else
                        {
                            int stt = 1;
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="text-center text-muted fw-bold align-middle">@(stt++)</td>
                                    <td class="ps-4 fw-bold text-success align-middle">
                                        #PX-@item.MaPhieuXuat.ToString("D5")
                                    </td>
                                    <td class="text-center">
                                        <span class="badge bg-light text-dark border">
                                            <i class="fa-regular fa-calendar"></i> @item.NgayXuat.ToString("dd/MM/yyyy HH:mm")
                                        </span>
                                    </td>
                                    <td class="text-center fw-bold">
                                        @item.TenKhachHang
                                        @if (!string.IsNullOrEmpty(item.SoDienThoaiKhach))
                                        {
                                            <br/><small class="fw-normal text-muted"><i class="fa-solid fa-phone"></i> @item.SoDienThoaiKhach</small>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <i class="fa-solid fa-user-pen text-muted"></i> @(item.MaNguoiDungNavigation?.HoTen ?? "Hệ thống")
                                    </td>
                                    <td class="text-end fw-bold text-danger">
                                        @string.Format("{0:N0}", item.TongTien) đ
                                    </td>
                                    <td class="text-center pe-4">
                                        <a asp-action="Details" asp-route-id="@item.MaPhieuXuat" class="btn btn-sm btn-info text-white shadow-sm" title="Xem Hóa Đơn">
                                            <i class="fa-solid fa-print"></i> Biên Lai
                                        </a>
                                        @if (User.IsInRole("Quản trị viên") || User.IsInRole("Admin") || User.IsInRole("Nhân viên bán hàng"))
                                        {
                                            <a asp-action="Delete" asp-route-id="@item.MaPhieuXuat" class="btn btn-sm btn-danger text-white shadow-sm ms-1" title="Hủy Phiếu / Khách Trả Hàng">
                                                <i class="fa-solid fa-rotate-left"></i> Trả Hàng
                                            </a>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
