@model QuanLyKhoLinhKienPC.Models.DanhMuc

@{
    ViewData["Title"] = "Thêm Mới Danh Mục";
}

<div class="container-fluid pt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow rounded-4 border-0" style="box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.05) !important;">
                <div class="card-header bg-white border-bottom border-light py-3">
                    <h4 class="mb-0 text-primary fw-bold"><i class="fa-solid fa-plus-circle me-1"></i> Thêm Mới Danh Mục</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert" style="display:none;"></div>

                        <div class="mb-3">
                            <label asp-for="TenDanhMuc" class="form-label fw-bold">Tên danh mục <span class="text-danger">*</span></label>
                            <input asp-for="TenDanhMuc" class="form-control form-control-lg bg-light border-0 rounded-3 fs-6" placeholder="Ví dụ: CPU, RAM, Mainboard..." autofocus />
                            <span asp-validation-for="TenDanhMuc" class="text-danger"></span>
                        </div>

                        <div class="d-flex justify-content-between mt-5">
                            <a asp-action="Index" class="btn btn-light border shadow-sm rounded-pill px-4 text-secondary fw-semibold">
                                <i class="fa-solid fa-arrow-left me-1"></i> Quay lại
                            </a>

                            <button type="submit" class="btn btn-primary shadow-sm rounded-pill px-5 fw-bold">
                                <i class="fa-solid fa-save me-1"></i> Lưu lại
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        $(document).ready(function() {
            if ($(".validation-summary-errors").length > 0) {
                $(".validation-summary-errors").addClass("alert alert-danger");
            }
        });
    </script>
}