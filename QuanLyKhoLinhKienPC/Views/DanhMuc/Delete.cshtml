@model QuanLyKhoLinhKienPC.Models.DanhMuc

@{
    ViewData["Title"] = "Xóa Danh Mục";
}

<div class="container-fluid pt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow rounded-4 border-0" style="box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.05) !important;">
                <div class="card-header bg-white border-bottom border-light py-3">
                    <h4 class="mb-0 text-danger fw-bold"><i class="fa-solid fa-triangle-exclamation me-1"></i> Xóa Danh Mục</h4>
                </div>
                <div class="card-body text-center p-4">
                    <h5 class="card-title text-danger mb-4">Bạn có chắc muốn chuyển Danh mục này vào thùng rác?</h5>

                    <p class="text-muted small mb-4">
                        <i class="fa-solid fa-circle-info"></i> Lưu ý: Dữ liệu sẽ được chuyển vào Thùng rác (có thể khôi phục lại khi cần).
                    </p>

                    <dl class="row mt-4 text-start justify-content-center bg-danger bg-opacity-10 py-4 rounded-4 mx-2">
                        <dt class="col-sm-4 text-end text-danger fw-semibold">Tên danh mục:</dt>
                        <dd class="col-sm-8 fw-bold text-dark fs-5 mb-0">@Html.DisplayFor(model => model.TenDanhMuc)</dd>
                    </dl>

                    <form asp-action="Delete" class="mt-5">
                        <input type="hidden" asp-for="MaDanhMuc" />
                        <a asp-action="Index" class="btn btn-light border shadow-sm rounded-pill px-4 text-secondary fw-semibold me-2">
                            <i class="fa-solid fa-xmark me-1"></i> Hủy bỏ
                        </a>
                        <button type="submit" class="btn btn-danger shadow-sm rounded-pill px-5 fw-bold">
                            <i class="fa-solid fa-trash me-1"></i> Đồng ý xóa
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>