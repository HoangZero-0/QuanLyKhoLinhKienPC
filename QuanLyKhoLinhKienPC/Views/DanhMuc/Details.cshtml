@model QuanLyKhoLinhKienPC.Models.DanhMuc

@{
    ViewData["Title"] = "Chi Tiết Danh Mục";
}

<div class="container-fluid pt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow rounded-4 border-0" style="box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.05) !important;">
                <div class="card-header bg-white border-bottom border-light py-3">
                    <h4 class="mb-0 text-info fw-bold"><i class="fa-solid fa-circle-info me-1"></i> Chi Tiết Danh Mục</h4>
                </div>
                <div class="card-body p-4">
                    <dl class="row mb-0">
                        <dt class="col-sm-4 text-muted fw-semibold">Tên danh mục:</dt>
                        <dd class="col-sm-8 fw-bold text-dark fs-5">@Html.DisplayFor(model => model.TenDanhMuc)</dd>

                        <dt class="col-sm-4 text-muted">Trạng thái:</dt>
                        <dd class="col-sm-8">
                            @if (Model.IsDeleted)
                            {
                                <span class="badge bg-danger">Đã xóa</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Đang hoạt động</span>
                            }
                        </dd>
                    </dl>
                </div>
                <div class="card-footer bg-white border-0 text-end pe-4 pb-4 pt-0">
                    <a asp-action="Index" class="btn btn-light border shadow-sm rounded-pill px-4 text-secondary fw-semibold me-2">
                        <i class="fa-solid fa-arrow-left me-1"></i> Quay lại
                    </a>
                    <a asp-action="Edit" asp-route-id="@Model?.MaDanhMuc" class="btn btn-warning shadow-sm rounded-pill px-4 fw-bold text-dark">
                        <i class="fa-solid fa-pen me-1"></i> Chỉnh sửa
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>