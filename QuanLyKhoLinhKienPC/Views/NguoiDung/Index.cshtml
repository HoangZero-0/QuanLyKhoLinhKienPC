@model IEnumerable<QuanLyKhoLinhKienPC.Models.NguoiDung>

@{
    ViewData["Title"] = "Quản Lý Người Dùng";
}

<div class="d-flex flex-column h-100">

    <div class="d-flex justify-content-between align-items-center mb-3 flex-shrink-0">
        <h2 class="text-primary m-0"><i class="fa-solid fa-users"></i> Quản Lý Người Dùng</h2>
        <div>
            <a asp-action="Trash" class="btn btn-outline-danger shadow-sm me-2" title="Thùng rác">
                <i class="fa-solid fa-trash-can"></i>
            </a>
            <a asp-action="Create" class="btn btn-success shadow-sm">
                <i class="fa-solid fa-user-plus"></i> Thêm người dùng
            </a>
        </div>
    </div>

    <div class="flex-shrink-0">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
                <i class="fa-solid fa-check-circle"></i> @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
    </div>

    <div class="card mb-3 shadow-sm flex-shrink-0 border-0">
        <div class="card-body py-2">
            <form asp-action="Index" method="get" class="row g-2 align-items-center">
                <div class="col-md-7">
                    <div class="input-group">
                        <span class="input-group-text bg-white text-muted border-end-0"><i class="fa-solid fa-magnifying-glass"></i></span>
                        <input type="text" name="searchString" class="form-control border-start-0 ps-0" placeholder="Nhập tên đăng nhập hoặc họ tên..." value="@ViewData["CurrentFilter"]">
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="input-group">
                        <span class="input-group-text bg-white text-muted"><i class="fa-solid fa-user-shield"></i></span>
                        <select name="MaVaiTro" class="form-select" asp-items="ViewBag.MaVaiTro" onchange="this.form.submit()">
                            <option value="">-- Tất cả vai trò --</option>
                        </select>
                    </div>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100 fw-bold">Tìm kiếm</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm flex-grow-1 overflow-hidden border-0">
        <div class="card-body p-0 position-relative">
            <div class="table-responsive" style="position: absolute; top: 0; bottom: 0; left: 0; right: 0;">
                <table class="table table-striped table-hover mb-0 w-100 align-middle">
                    <thead class="table-primary">
                        <tr>
                            <th class="py-3 ps-3 text-center" style="width: 5%; position: sticky; top: 0; z-index: 10;">STT</th>
                            <th class="py-3 ps-3" style="position: sticky; top: 0; z-index: 10;">
                                Họ tên
                            </th>
                            <th class="py-3" style="position: sticky; top: 0; z-index: 10;">
                                Tên đăng nhập
                            </th>
                            <th class="py-3" style="position: sticky; top: 0; z-index: 10;">
                                Vai trò
                            </th>
                            <th class="py-3" style="position: sticky; top: 0; z-index: 10;">
                                Email
                            </th>
                            <th class="text-center py-3" style="width: 150px; position: sticky; top: 0; z-index: 10;">
                                Hành động
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            int stt = 1;
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="text-center text-muted fw-bold align-middle">@(stt++)</td>
                                    <td class="fw-bold text-primary ps-3 py-3 align-middle">
                                        <a asp-action="Details" asp-route-id="@item.MaNguoiDung" class="text-decoration-none d-flex align-items-center">
                                            @Html.DisplayFor(modelItem => item.HoTen)
                                        </a>
                                    </td>
                                    <td class="py-3">
                                        @Html.DisplayFor(modelItem => item.TenDangNhap)
                                    </td>
                                    <td class="py-3">
                                        <span class="badge bg-info text-dark">@item.MaVaiTroNavigation?.TenVaiTro</span>
                                    </td>
                                    <td class="py-3 text-muted">
                                        @Html.DisplayFor(modelItem => item.Email)
                                    </td>
                                    <td class="text-center py-2">
                                        <div class="d-flex justify-content-center gap-2">
                                            <a asp-action="Details" asp-route-id="@item.MaNguoiDung" class="btn btn-sm btn-info text-white" title="Xem chi tiết">
                                                <i class="fa-solid fa-eye"></i>
                                            </a>

                                            <a asp-action="Delete" asp-route-id="@item.MaNguoiDung" class="btn btn-sm btn-danger" title="Xóa">
                                                <i class="fa-solid fa-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-5">
                                    <i class="fa-solid fa-users fa-3x mb-3 text-secondary opacity-50"></i><br>
                                    Không tìm thấy dữ liệu nào.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
