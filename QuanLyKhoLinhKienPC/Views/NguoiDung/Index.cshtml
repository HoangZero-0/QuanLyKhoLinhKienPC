@model IEnumerable<QuanLyKhoLinhKienPC.Models.NguoiDung>

@{
    ViewData["Title"] = "Quản Lý Nhân Viên";
}

<div class="d-flex flex-column h-100">

    <div class="d-flex justify-content-between align-items-center mb-3 flex-shrink-0">
        <h2 class="text-primary m-0"><i class="fa-solid fa-users"></i> Quản Lý Nhân Viên</h2>
        <div>
            <a asp-action="Trash" class="btn btn-light border shadow-sm rounded-pill px-3 transition text-danger" title="Thùng rác">
                <i class="fa-solid fa-trash-can"></i>
            </a>
                <a asp-action="Create" class="btn btn-primary shadow-sm rounded-pill px-4">
                    <i class="fa-solid fa-plus me-1"></i> Thêm mới
                </a>
        </div>
    </div>

    <div class="flex-shrink-0">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
                <i class="fa-solid fa-check-circle"></i> @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
                <i class="fa-solid fa-circle-exclamation"></i> @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
    </div>

    <div class="card mb-4 shadow rounded-4 flex-shrink-0 border-0" style="box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.05), 0 2px 4px -2px rgb(0 0 0 / 0.05) !important;">
        <div class="card-body py-3 px-4">
            <form asp-action="Index" method="get" class="row g-3 align-items-center">
                <div class="col-md-7">
                    <div class="input-group input-group-lg">
                        <span class="input-group-text bg-white text-muted border-end-0 rounded-start-pill ps-4"><i class="fa-solid fa-magnifying-glass"></i></span>
                        <input type="text" name="searchString" class="form-control border-start-0 rounded-end-pill fs-6 ps-0" placeholder="Nhập tên đăng nhập hoặc họ tên..." value="@ViewData["CurrentFilter"]">
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="input-group input-group-lg">
                        <span class="input-group-text bg-white text-muted border-end-0 rounded-start-pill ps-4"><i class="fa-solid fa-user-shield"></i></span>
                        <select name="MaVaiTro" class="form-select border-start-0 rounded-end-pill fs-6 ps-0" asp-items="ViewBag.MaVaiTro" onchange="this.form.submit()">
                            <option value="">-- Tất cả vai trò --</option>
                        </select>
                    </div>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-dark btn-lg w-100 fw-bold rounded-pill fs-6 shadow-sm">Tìm kiếm</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow rounded-4 flex-grow-1 overflow-hidden border-0" style="box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.05), 0 4px 6px -4px rgb(0 0 0 / 0.05) !important;">
        <div class="card-body p-0 position-relative">
            <div class="table-responsive" style="position: absolute; top: 0; bottom: 0; left: 0; right: 0; overflow-x: hidden;">
                <style>
                    .premium-table tbody tr {
                        transition: all 0.2s;
                        border-bottom: 1px solid #f1f5f9;
                    }
                    .premium-table tbody tr:hover {
                        background-color: #f8fafc !important;
                        transform: scale(1.002);
                    }
                    .premium-table th {
                        border-bottom: 2px solid #e2e8f0 !important;
                        color: #64748b;
                        font-weight: 600;
                        text-transform: uppercase;
                        font-size: 0.85rem;
                        letter-spacing: 0.5px;
                    }
                </style>
                <table class="table premium-table mb-0 w-100 align-middle">
                    <thead class="bg-white">
                        <tr>
                            <th class="py-4 ps-4 text-center" style="width: 5%; position: sticky; top: 0; z-index: 10; background: rgba(255,255,255,0.95); backdrop-filter: blur(8px);">STT</th>
                            <th class="py-4 ps-3" style="width: 25%; position: sticky; top: 0; z-index: 10; background: rgba(255,255,255,0.95); backdrop-filter: blur(8px);">
                                Họ tên
                            </th>
                            <th class="py-4" style="width: 20%; position: sticky; top: 0; z-index: 10; background: rgba(255,255,255,0.95); backdrop-filter: blur(8px);">
                                Tên đăng nhập
                            </th>
                            <th class="py-4" style="width: 15%; position: sticky; top: 0; z-index: 10; background: rgba(255,255,255,0.95); backdrop-filter: blur(8px);">
                                Vai trò
                            </th>
                            <th class="py-4" style="width: 20%; position: sticky; top: 0; z-index: 10; background: rgba(255,255,255,0.95); backdrop-filter: blur(8px);">
                                Email
                            </th>
                            <th class="text-center py-4 pe-4" style="width: 15%; position: sticky; top: 0; z-index: 10; background: rgba(255,255,255,0.95); backdrop-filter: blur(8px);">
                                Thao tác
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            int stt = 1;
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="text-center text-secondary fw-medium align-middle ps-4">@(stt++)</td>
                                    <td class="fw-bold text-dark ps-3 py-4 align-middle">
                                        <a asp-action="Details" asp-route-id="@item.MaNguoiDung" class="text-decoration-none text-dark hover-primary transition">
                                            @Html.DisplayFor(modelItem => item.HoTen)
                                        </a>
                                    </td>
                                    <td class="text-secondary fw-normal">
                                        @Html.DisplayFor(modelItem => item.TenDangNhap)
                                    </td>
                                    <td>
                                        <span class="badge rounded-pill bg-info bg-opacity-10 text-info px-3 fw-bold">
                                            <i class="fa-solid fa-shield-user me-1"></i> @item.MaVaiTroNavigation?.TenVaiTro
                                        </span>
                                    </td>
                                    <td class="text-muted fw-normal">
                                        @Html.DisplayFor(modelItem => item.Email)
                                    </td>
                                    <td class="text-center py-4 pe-4">
                                        <div class="d-inline-flex gap-2">
                                            <a asp-action="Details" asp-route-id="@item.MaNguoiDung" class="btn btn-sm btn-light border text-info rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 35px; height: 35px;" title="Xem chi tiết">
                                                <i class="fa-solid fa-eye"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.MaNguoiDung" class="btn btn-sm btn-light border text-danger rounded-circle d-inline-flex align-items-center justify-content-center transition shadow-xs" style="width: 35px; height: 35px;" title="Xóa">
                                                <i class="fa-solid fa-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-5">
                                    <div class="py-4">
                                        <i class="fa-solid fa-users fa-3x mb-3 text-secondary opacity-25"></i>
                                        <p class="fs-5 fw-medium mb-1">Không tìm thấy dữ liệu nào</p>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
