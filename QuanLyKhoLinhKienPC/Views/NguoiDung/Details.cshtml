@model QuanLyKhoLinhKienPC.Models.NguoiDung

@{
    ViewData["Title"] = "Chi Tiết Nhân Viên";
}

<div class="container-fluid pt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow rounded-4 border-0" style="box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.05) !important;">
                <div class="card-header bg-white border-bottom border-light py-3">
                    <h4 class="mb-0 text-info fw-bold"><i class="fa-solid fa-eye me-1"></i> Chi Tiết Nhân Viên</h4>
                </div>
                <div class="card-body p-4">
                    <dl class="row mb-0 mt-2">
                        <dt class="col-sm-4 text-muted fw-semibold mb-3">Họ tên:</dt>
                        <dd class="col-sm-8 fw-bold text-dark fs-5 mb-3">@Html.DisplayFor(model => model.HoTen)</dd>

                        <dt class="col-sm-4 text-muted fw-semibold mb-3">Tài khoản:</dt>
                        <dd class="col-sm-8 mb-3">
                            <span class="text-dark">@Html.DisplayFor(model => model.TenDangNhap)</span>
                        </dd>

                        <dt class="col-sm-4 text-muted fw-semibold mb-3">Vai trò:</dt>
                        <dd class="col-sm-8 mb-3">
                            <span class="text-dark">@Model.MaVaiTroNavigation?.TenVaiTro</span>
                        </dd>

                        <dt class="col-sm-4 text-muted fw-semibold mb-3">Email:</dt>
                        <dd class="col-sm-8 mb-3">
                            @if (!string.IsNullOrEmpty(Model.Email))
                            {
                                <span class="text-dark">@Html.DisplayFor(model => model.Email)</span>
                            }
                            else
                            {
                                <span class="text-muted fst-italic">--- Chưa cập nhật ---</span>
                            }
                        </dd>

                        <dt class="col-sm-4 text-muted fw-semibold">Trạng thái:</dt>
                        <dd class="col-sm-8">
                            @if (Model.IsDeleted)
                            {
                                <span class="badge bg-danger">Đã xóa</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Đang hoạt động</span>
                            }
                        </dd>
                    </dl>
                </div>
                <div class="card-footer bg-white border-top-0 p-4 pt-0">
                    <a asp-action="Index" class="btn btn-light border shadow-sm rounded-pill px-4 text-secondary fw-semibold">
                        <i class="fa-solid fa-arrow-left me-1"></i> Quay lại
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
