@model IEnumerable<QuanLyKhoLinhKienPC.Models.NguoiDung>

@{
    ViewData["Title"] = "Thùng Rác Nhân Viên";
}

<div class="d-flex flex-column h-100">

    <div class="d-flex justify-content-between align-items-center mb-3 flex-shrink-0">
        <h2 class="text-danger m-0"><i class="fa-solid fa-user-slash"></i> Thùng Rác Nhân Viên</h2>
        <div>
            <a asp-action="Index" class="btn btn-light border shadow-sm me-2 rounded-pill px-4">
                <i class="fa-solid fa-arrow-left me-1"></i> Quay lại
            </a>
        </div>
    </div>


    <div class="card mb-4 shadow rounded-4 flex-shrink-0 border-0" style="box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.05), 0 2px 4px -2px rgb(0 0 0 / 0.05) !important;">
        <div class="card-body py-3 px-4">
            <form asp-action="Trash" method="get" class="row g-3 align-items-center">
                <div class="col-md-7">
                    <div class="input-group input-group-lg">
                        <span class="input-group-text bg-white text-muted border-end-0 rounded-start-pill ps-4"><i class="fa-solid fa-magnifying-glass"></i></span>
                        <input type="text" name="searchString" class="form-control border-start-0 rounded-end-pill fs-6 ps-0" placeholder="Nhập tên đăng nhập hoặc họ tên..." value="@ViewData["CurrentFilter"]">
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="input-group input-group-lg">
                        <span class="input-group-text bg-white text-muted border-end-0 rounded-start-pill ps-4"><i class="fa-solid fa-user-shield"></i></span>
                        <select name="MaVaiTro" class="form-select border-start-0 rounded-end-pill fs-6 ps-0" asp-items="ViewBag.MaVaiTro" onchange="this.form.submit()">
                            <option value="">-- Tất cả vai trò --</option>
                        </select>
                    </div>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-dark btn-lg w-100 fw-bold rounded-pill fs-6 shadow-sm">Tìm kiếm</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow rounded-4 flex-grow-1 overflow-hidden border-0" style="box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.05), 0 4px 6px -4px rgb(0 0 0 / 0.05) !important;">
        <div class="card-body p-0 position-relative">
            <div class="table-responsive" style="position: absolute; top: 0; bottom: 0; left: 0; right: 0; overflow-x: hidden;">
                <style>
                    .premium-table tbody tr {
                        transition: all 0.2s;
                        border-bottom: 1px solid #f1f5f9;
                    }
                    .premium-table tbody tr:hover {
                        background-color: #fca5a510 !important;
                        transform: scale(1.002);
                    }
                    .premium-table th {
                        border-bottom: 2px solid #fecaca !important;
                        color: #ef4444;
                        font-weight: 600;
                        text-transform: uppercase;
                        font-size: 0.85rem;
                        letter-spacing: 0.5px;
                    }
                </style>
                <table class="table premium-table mb-0 w-100 align-middle">
                    <thead class="bg-white">
                        <tr>
                            <th class="py-4 ps-4 text-center" style="width: 5%; position: sticky; top: 0; z-index: 10; background: rgba(255,255,255,0.95); backdrop-filter: blur(8px);">STT</th>
                            <th class="py-4 ps-3" style="position: sticky; top: 0; z-index: 10; background: rgba(255,255,255,0.95); backdrop-filter: blur(8px);">
                                Họ tên
                            </th>
                            <th class="py-4" style="position: sticky; top: 0; z-index: 10; background: rgba(255,255,255,0.95); backdrop-filter: blur(8px);">
                                Tên đăng nhập
                            </th>
                            <th class="py-4" style="position: sticky; top: 0; z-index: 10; background: rgba(255,255,255,0.95); backdrop-filter: blur(8px);">
                                Vai trò
                            </th>
                            <th class="text-center py-4 pe-4" style="width: 150px; position: sticky; top: 0; z-index: 10; background: rgba(255,255,255,0.95); backdrop-filter: blur(8px);">
                                Hành động
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            int stt = 1;
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="text-center text-secondary fw-medium align-middle ps-4">@(stt++)</td>
                                    <td class="fw-bold text-dark ps-3 py-4 align-middle">
                                        @Html.DisplayFor(modelItem => item.HoTen)
                                    </td>
                                    <td>
                                        <code>@Html.DisplayFor(modelItem => item.TenDangNhap)</code>
                                    </td>
                                    <td>
                                        <span class="badge rounded-pill bg-secondary bg-opacity-10 text-secondary px-3">
                                            @item.MaVaiTroNavigation?.TenVaiTro
                                        </span>
                                    </td>
                                    <td class="py-4 d-flex justify-content-center pe-4">
                                        <form asp-action="Restore" asp-route-id="@item.MaNguoiDung" method="post" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-light border text-success rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 35px; height: 35px;" title="Khôi phục tài khoản">
                                                <i class="fa-solid fa-rotate-left"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-5">
                                    <i class="fa-regular fa-trash-can fa-3x mb-3 text-secondary opacity-50"></i><br>
                                    Thùng rác trống.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
