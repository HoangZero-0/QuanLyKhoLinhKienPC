@model QuanLyKhoLinhKienPC.Models.NguoiDung

@{
    ViewData["Title"] = "Thêm Mới Nhân Viên";
}

<div class="container-fluid pt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow rounded-4 border-0" style="box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.05) !important;">
                <div class="card-header bg-white border-bottom border-light py-3">
                    <h4 class="mb-0 text-primary fw-bold"><i class="fa-solid fa-plus-circle me-2"></i> Thêm Mới Nhân Viên</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert" style="display:none;"></div>

                        <div class="row g-4">
                            <div class="col-md-6">
                                <label asp-for="TenDangNhap" class="form-label fw-bold">Tên đăng nhập <span class="text-danger">*</span></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-0"><i class="fa-solid fa-user"></i></span>
                                    <input asp-for="TenDangNhap" class="form-control form-control-lg bg-light border-0 fs-6" placeholder="Ví dụ: admin, nv01..." autofocus />
                                </div>
                                <span asp-validation-for="TenDangNhap" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="MatKhau" class="form-label fw-bold">Mật khẩu <span class="text-danger">*</span></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-0"><i class="fa-solid fa-key"></i></span>
                                    <input asp-for="MatKhau" type="password" class="form-control form-control-lg bg-light border-0 fs-6" placeholder="Nhập mật khẩu..." />
                                </div>
                                <span asp-validation-for="MatKhau" class="text-danger small"></span>
                            </div>

                            <div class="col-md-12">
                                <label asp-for="HoTen" class="form-label fw-bold">Họ và tên</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-0"><i class="fa-solid fa-id-card"></i></span>
                                    <input asp-for="HoTen" class="form-control form-control-lg bg-light border-0 fs-6" placeholder="Nhập họ và tên người dùng..." />
                                </div>
                                <span asp-validation-for="HoTen" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Email" class="form-label fw-bold">Email</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-0"><i class="fa-solid fa-envelope"></i></span>
                                    <input asp-for="Email" type="email" class="form-control form-control-lg bg-light border-0 fs-6" placeholder="Ví dụ: email@domain.com" />
                                </div>
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="MaVaiTro" class="form-label fw-bold">Vai trò <span class="text-danger">*</span></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-0"><i class="fa-solid fa-user-shield"></i></span>
                                    <select asp-for="MaVaiTro" class="form-select form-select-lg bg-light border-0 fs-6" asp-items="@(ViewData["MaVaiTro"] as SelectList)">
                                        <option value="">-- Chọn vai trò --</option>
                                    </select>
                                </div>
                                <span asp-validation-for="MaVaiTro" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between mt-5">
                            <a asp-action="Index" class="btn btn-light border shadow-sm rounded-pill px-4 text-secondary fw-semibold">
                                <i class="fa-solid fa-arrow-left me-1"></i> Quay lại
                            </a>

                            <button type="submit" class="btn btn-primary shadow-sm rounded-pill px-5 fw-bold">
                                <i class="fa-solid fa-save me-1"></i> Lưu lại
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        $(document).ready(function() {
            if ($(".validation-summary-errors").length > 0) {
                $(".validation-summary-errors").addClass("alert alert-danger rounded-4");
            }
        });
    </script>
}
