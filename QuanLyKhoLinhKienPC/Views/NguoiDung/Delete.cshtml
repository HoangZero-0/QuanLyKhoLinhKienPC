@model QuanLyKhoLinhKienPC.Models.NguoiDung

@{
    ViewData["Title"] = "Xóa Người Dùng";
}

<div class="container-fluid pt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-danger">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0"><i class="fa-solid fa-triangle-exclamation"></i> Xóa Người Dùng</h4>
                </div>
                <div class="card-body text-center">
                    <h5 class="card-title text-danger mb-4">Bạn có chắc muốn chuyển Người dùng này vào thùng rác?</h5>

                    <p class="text-muted small mb-4">
                        <i class="fa-solid fa-circle-info"></i> Lưu ý: Dữ liệu sẽ được chuyển vào Thùng rác và tài khoản này sẽ không thể đăng nhập.
                    </p>

                    <dl class="row mt-3 text-start justify-content-center bg-light py-3 rounded mx-3">
                        <dt class="col-sm-5 text-end text-muted">Tên đăng nhập:</dt>
                        <dd class="col-sm-5 fw-bold">@Html.DisplayFor(model => model.TenDangNhap)</dd>

                        <dt class="col-sm-5 text-end text-muted">Họ và tên:</dt>
                        <dd class="col-sm-5 fw-bold text-primary">@Html.DisplayFor(model => model.HoTen)</dd>

                        <dt class="col-sm-5 text-end text-muted">Vai trò:</dt>
                        <dd class="col-sm-5"><span class="badge bg-secondary">@Model.MaVaiTroNavigation?.TenVaiTro</span></dd>
                    </dl>

                    <form asp-action="Delete" class="mt-4">
                        <input type="hidden" asp-for="MaNguoiDung" />
                        <a asp-action="Index" class="btn btn-secondary me-2">
                            <i class="fa-solid fa-xmark"></i> Hủy bỏ
                        </a>
                        <button type="submit" class="btn btn-danger">
                            <i class="fa-solid fa-trash"></i> Đồng ý xóa
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
