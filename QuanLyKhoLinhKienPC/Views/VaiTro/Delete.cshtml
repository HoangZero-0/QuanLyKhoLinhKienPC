@model QuanLyKhoLinhKienPC.Models.VaiTro

@{
    ViewData["Title"] = "Xóa Vai Trò";
}

<div class="container-fluid pt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-danger">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0"><i class="fa-solid fa-triangle-exclamation"></i> Xóa Vai Trò</h4>
                </div>
                <div class="card-body text-center">
                    <h5 class="card-title text-danger mb-4">Bạn có chắc muốn chuyển Vai trò này vào thùng rác?</h5>

                    <p class="text-muted small mb-4">
                        <i class="fa-solid fa-circle-info"></i> Lưu ý: Dữ liệu sẽ được chuyển vào Thùng rác (có thể khôi phục lại khi cần).
                    </p>

                    <dl class="row mt-3 text-start justify-content-center bg-light py-3 rounded mx-3">
                        <dt class="col-sm-5 text-end">Tên vai trò:</dt>
                        <dd class="col-sm-5 fw-bold">@Html.DisplayFor(model => model.TenVaiTro)</dd>
                    </dl>

                    <form asp-action="Delete" class="mt-4">
                        <input type="hidden" asp-for="MaVaiTro" />
                        <a asp-action="Index" class="btn btn-secondary me-2">
                            <i class="fa-solid fa-xmark"></i> Hủy bỏ
                        </a>
                        <button type="submit" class="btn btn-danger">
                            <i class="fa-solid fa-trash"></i> Đồng ý xóa
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>