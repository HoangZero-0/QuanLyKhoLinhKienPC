@model QuanLyKhoLinhKienPC.Models.SanPham

@{
    ViewData["Title"] = "Cập Nhật Sản Phẩm";
}

<style>
    .content { overflow-y: hidden !important; }
</style>

<div class="container-fluid pt-2">
    <div class="row justify-content-center">
        <div class="col-xl-10">
            <div class="card shadow rounded-4 border-0 mb-4" style="box-shadow: 0 15px 30px -5px rgb(0 0 0 / 0.05) !important;">
                <div class="card-header bg-warning bg-opacity-10 py-3 border-bottom-0">
                    <h4 class="mb-0 text-warning fw-bold"><i class="fa-solid fa-pen-to-square me-2"></i> Cập Nhật Sản Phẩm</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-4 shadow-sm py-2 mb-4" role="alert" style="display:none;"></div>
                        
                        <input type="hidden" asp-for="MaSanPham" />
                        <input type="hidden" asp-for="HinhAnh" />
                        <input type="hidden" asp-for="IsDeleted" />

                        <div class="row g-5">
                            <!-- LEFT: IMAGE PREVIEW -->
                            <div class="col-md-4">
                                <div class="text-center">
                                    <label class="form-label fw-bold text-dark mb-3">Hình Ảnh Sản Phẩm</label>
                                    <div class="bg-light rounded-4 p-3 mb-3 d-flex align-items-center justify-content-center overflow-hidden border shadow-inner" style="height: 250px;">
                                        <img id="imgPreview" src="@(string.IsNullOrEmpty(Model.HinhAnh) ? "/images/no-image.png" : Model.HinhAnh)" 
                                             alt="Preview" class="img-fluid rounded transition shadow-sm" style="max-height: 100%; object-fit: contain;" />
                                    </div>
                                    <div class="position-relative">
                                        <input type="file" name="fHinhAnh" id="fileInput" class="form-control d-none" onchange="previewImage(this)" accept="image/*" />
                                        <button type="button" class="btn btn-light border rounded-pill px-4 fw-bold w-100 mb-2 transition" onclick="document.getElementById('fileInput').click()">
                                            <i class="fa-solid fa-cloud-arrow-up me-2"></i> Thay đổi ảnh
                                        </button>
                                        <small class="text-muted d-block">Ảnh hiện tại sẽ được thay thế nếu bạn chọn tệp mới.</small>
                                        <span asp-validation-for="HinhAnh" class="text-danger small"></span>
                                    </div>
                                </div>
                            </div>

                            <!-- RIGHT: FORM FIELDS -->
                            <div class="col-md-8">
                                <div class="row g-3">
                                    <div class="col-md-12 mb-2">
                                        <label asp-for="TenSanPham" class="form-label fw-bold text-secondary small text-uppercase ms-1">Tên Sản Phẩm <span class="text-danger">*</span></label>
                                        <input asp-for="TenSanPham" class="form-control form-control-lg rounded-pill fs-6 transition border-light shadow-xs" placeholder="Tên sản phẩm..." />
                                        <span asp-validation-for="TenSanPham" class="text-danger small"></span>
                                    </div>

                                    <div class="col-md-6 mb-2">
                                        <label asp-for="MaDanhMuc" class="form-label fw-bold text-secondary small text-uppercase ms-1">Danh Mục <span class="text-danger">*</span></label>
                                        <select asp-for="MaDanhMuc" class="form-select form-select-lg rounded-pill fs-6 transition border-light shadow-xs" asp-items="ViewBag.MaDanhMuc">
                                        </select>
                                        <span asp-validation-for="MaDanhMuc" class="text-danger small"></span>
                                    </div>

                                    <div class="col-md-6 mb-2">
                                        <label asp-for="HangSanXuat" class="form-label fw-bold text-secondary small text-uppercase ms-1">Hãng Sản Xuất</label>
                                        <input asp-for="HangSanXuat" class="form-control form-control-lg rounded-pill fs-6 transition border-light shadow-xs" placeholder="Hãng sản xuất..." />
                                        <span asp-validation-for="HangSanXuat" class="text-danger small"></span>
                                    </div>

                                    <div class="col-md-6 mb-2">
                                        <label asp-for="GiaBan" class="form-label fw-bold text-secondary small text-uppercase ms-1">Giá Bán (VNĐ) <span class="text-danger">*</span></label>
                                        <div class="input-group">
                                            <input asp-for="GiaBan" type="number" class="form-control form-control-lg rounded-pill fs-6 transition border-light shadow-xs" />
                                            <span class="input-group-text bg-transparent border-0 fw-bold text-danger">VNĐ</span>
                                        </div>
                                        <span asp-validation-for="GiaBan" class="text-danger small"></span>
                                    </div>

                                    <div class="col-md-6 mb-2">
                                        <label asp-for="ThoiGianBaoHanh" class="form-label fw-bold text-secondary small text-uppercase ms-1">Bảo Hành (Tháng) <span class="text-danger">*</span></label>
                                        <input asp-for="ThoiGianBaoHanh" type="number" class="form-control form-control-lg rounded-pill fs-6 transition border-light shadow-xs" />
                                        <span asp-validation-for="ThoiGianBaoHanh" class="text-danger small"></span>
                                    </div>

                                    <div class="col-12 mt-3">
                                        <div class="card bg-light border-0 rounded-4">
                                            <div class="card-body p-3">
                                                <label asp-for="ThongSoKyThuat" class="form-label fw-bold text-dark flex align-center mb-1">
                                                    <i class="fa-solid fa-list-check me-2 text-primary"></i> Thông số kỹ thuật
                                                </label>
                                                <small class="text-muted d-block mb-3 ms-4"><i class="fa-solid fa-circle-info"></i> Định dạng: <code>Tên thông số: Giá trị</code> (Mỗi dòng một mục)</small>
                                                <textarea asp-for="ThongSoKyThuat" class="form-control rounded-4 border-0 transition p-3 shadow-inner" rows="4"
                                                          placeholder="Nhập thông số kỹ thuật..."></textarea>
                                                <span asp-validation-for="ThongSoKyThuat" class="text-danger small"></span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between mt-4 pt-3 border-top">
                            <a asp-action="Index" class="btn btn-light border rounded-pill px-4 fw-medium transition text-secondary">
                                <i class="fa-solid fa-arrow-left me-1"></i> Quay lại
                            </a>
                            <button type="submit" class="btn btn-warning shadow rounded-pill px-5 fw-bold transition">
                                <i class="fa-solid fa-save me-1"></i> Cập nhật
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        var originalSrc = "";
        $(document).ready(function() { originalSrc = $('#imgPreview').attr('src'); });

        function previewImage(input) {
            if (input.files && input.files[0]) {
                var file = input.files[0];
                var reader = new FileReader();
                reader.onload = function (e) {
                    $('#imgPreview').attr('src', e.target.result);
                }
                reader.readAsDataURL(file);
            } else {
                $('#imgPreview').attr('src', originalSrc);
            }
        }
    </script>
}