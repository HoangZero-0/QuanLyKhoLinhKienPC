@model QuanLyKhoLinhKienPC.Models.SanPham

@{
    ViewData["Title"] = "Xóa Sản Phẩm";
}

<div class="container-fluid pt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-danger">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0"><i class="fa-solid fa-triangle-exclamation"></i> Xóa Sản Phẩm</h4>
                </div>
                <div class="card-body text-center">
                    <h5 class="card-title text-danger mb-3">Bạn có chắc muốn chuyển Sản phẩm này vào thùng rác?</h5>

                    <p class="text-muted small mb-4">
                        <i class="fa-solid fa-circle-info"></i> Lưu ý: Sản phẩm sẽ được chuyển vào Thùng rác (có thể khôi phục lại khi cần).
                    </p>

                    <div class="mb-3">
                        <img src="@(string.IsNullOrEmpty(Model.HinhAnh) ? "/images/no-image.png" : Model.HinhAnh)"
                             alt="@Model.TenSanPham"
                             class="rounded shadow-sm border"
                             style="width: 120px; height: 120px; object-fit: contain; background: #f8f9fa;">
                    </div>

                    <dl class="row mt-3 text-start justify-content-center bg-light py-3 rounded mx-3">
                        <dt class="col-sm-4 text-end text-muted">Tên sản phẩm:</dt>
                        <dd class="col-sm-7 fw-bold text-dark">@Html.DisplayFor(model => model.TenSanPham)</dd>

                        <dt class="col-sm-4 text-end text-muted">Danh mục:</dt>
                        <dd class="col-sm-7">
                            <span class="badge bg-secondary">@(Model.MaDanhMucNavigation?.TenDanhMuc ?? "Chưa phân loại")</span>
                        </dd>

                        <dt class="col-sm-4 text-end text-muted">Hãng sản xuất:</dt>
                        <dd class="col-sm-7 fw-bold text-info">@(string.IsNullOrEmpty(Model.HangSanXuat) ? "N/A" : Model.HangSanXuat)</dd>

                        <dt class="col-sm-4 text-end text-muted">Giá bán:</dt>
                        <dd class="col-sm-7 text-danger fw-bold">@Model.GiaBan.ToString("N0") VNĐ</dd>
                    </dl>

                    <form asp-action="Delete" class="mt-4">
                        <input type="hidden" asp-for="MaSanPham" />

                        <a asp-action="Index" class="btn btn-secondary me-2">
                            <i class="fa-solid fa-xmark"></i> Hủy bỏ
                        </a>
                        <button type="submit" class="btn btn-danger">
                            <i class="fa-solid fa-trash"></i> Đồng ý xóa
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>