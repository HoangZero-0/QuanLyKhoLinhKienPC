@model QuanLyKhoLinhKienPC.Models.SanPham

@{
    ViewData["Title"] = "Xóa Sản Phẩm";
}

<style>
    .content { overflow-y: hidden !important; }
</style>

<div class="container-fluid pt-4">
    <div class="row justify-content-center g-4">
        <div class="col-md-6">
            <div class="card shadow rounded-4 border-0" style="box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.05) !important;">
                <div class="card-header bg-white border-bottom border-light py-3">
                    <h4 class="mb-0 text-danger fw-bold"><i class="fa-solid fa-triangle-exclamation me-1"></i> Xóa Sản Phẩm</h4>
                </div>
                <div class="card-body text-center p-4">
                    <h5 class="card-title text-danger mb-4">Bạn có chắc muốn chuyển Sản phẩm này vào thùng rác?</h5>

                    <p class="text-muted small mb-4">
                        <i class="fa-solid fa-circle-info"></i> Lưu ý: Dữ liệu sẽ được chuyển vào Thùng rác (có thể khôi phục lại khi cần).
                    </p>

                    <div class="bg-danger bg-opacity-10 py-4 rounded-4 mx-2 text-start shadow-inner border border-danger border-opacity-10">
                        <div class="text-center mb-4">
                            <div class="bg-white p-2 rounded-3 shadow-sm d-inline-block border">
                                <img src="@(string.IsNullOrEmpty(Model.HinhAnh) ? "/images/no-image.png" : Model.HinhAnh)"
                                     alt="@Model.TenSanPham"
                                     class="img-fluid rounded"
                                     style="width: 150px; height: 150px; object-fit: contain;">
                            </div>
                        </div>
                        <div class="row px-4 align-items-center g-2 pb-2">
                             <div class="col-sm-4 text-danger fw-semibold">Tên Sản Phẩm:</div>
                            <div class="col-sm-8 fw-bold text-dark fs-5">@Model.TenSanPham</div>
                            
                            <div class="col-sm-4 text-danger fw-semibold">Danh Mục:</div>
                            <div class="col-sm-8 text-dark">@(Model.MaDanhMucNavigation?.TenDanhMuc ?? "Chưa phân loại")</div>

                            <div class="col-sm-4 text-danger fw-semibold">Hãng Sản Xuất:</div>
                            <div class="col-sm-8 text-dark">@(string.IsNullOrEmpty(Model.HangSanXuat) ? "N/A" : Model.HangSanXuat)</div>
                            
                            <div class="col-sm-4 text-danger fw-semibold">Giá Niêm Yết:</div>
                            <div class="col-sm-8 text-dark">@Model.GiaBan.ToString("N0") VNĐ</div>
                        </div>
                    </div>

                    <form asp-action="Delete" class="mt-5 d-flex justify-content-between px-2">
                        <input type="hidden" asp-for="MaSanPham" />
                        <a asp-action="Index" class="btn btn-light border shadow-sm rounded-pill px-4 text-secondary fw-semibold transition">
                            <i class="fa-solid fa-xmark me-1"></i> Hủy bỏ
                        </a>
                        <button type="submit" class="btn btn-danger shadow rounded-pill px-5 fw-bold transition">
                            <i class="fa-solid fa-trash me-1"></i> Đồng ý xóa
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>