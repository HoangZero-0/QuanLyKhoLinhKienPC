@model IEnumerable<QuanLyKhoLinhKienPC.Models.SanPham>

@{
    ViewData["Title"] = "Quản Lý Sản Phẩm";
}

<div class="d-flex flex-column h-100">
    <!-- HEADER & ACTIONS -->
    <div class="d-flex justify-content-between align-items-center mb-3 flex-shrink-0">
        <h2 class="text-primary m-0"><i class="fa-solid fa-box-open"></i> Quản Lý Sản Phẩm</h2>
        @if (User.IsInRole("Quản trị viên") || User.IsInRole("Admin") || User.IsInRole("Nhân viên kho"))
        {
            <div>
                <a asp-action="Trash" class="btn btn-light border shadow-sm rounded-pill px-3 transition text-danger" title="Thùng rác">
                    <i class="fa-solid fa-trash-can"></i>
                </a>
                <a asp-action="Create" class="btn btn-primary shadow-sm rounded-pill px-4 transition">
                    <i class="fa-solid fa-plus me-1"></i> Thêm mới
                </a>
            </div>
        }
    </div>

    <!-- FILTER BAR -->
    <div class="card mb-4 shadow rounded-4 flex-shrink-0 border-0" style="box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.05) !important;">
        <div class="card-body py-3 px-4">
            <form asp-action="Index" method="get" class="row g-3 align-items-center">
                <div class="col-md-5">
                    <div class="input-group input-group-lg">
                        <span class="input-group-text bg-white text-muted border-end-0 rounded-start-pill ps-4"><i class="fa-solid fa-magnifying-glass"></i></span>
                        <input type="text" name="searchString" class="form-control border-start-0 rounded-end-pill fs-6 ps-0" placeholder="Tìm tên sản phẩm..." value="@ViewData["CurrentFilter"]">
                    </div>
                </div>

                <div class="col-md-2">
                    <select name="MaDanhMuc" class="form-select form-select-lg rounded-pill fs-6 transition border" asp-items="ViewBag.MaDanhMuc" onchange="this.form.submit()">
                        <option value="">-- Danh mục --</option>
                    </select>
                </div>

                <div class="col-md-2">
                    <select name="HangSanXuat" class="form-select form-select-lg rounded-pill fs-6 transition border" asp-items="ViewBag.HangSanXuatList" onchange="this.form.submit()">
                        <option value="">-- Hãng sản xuất --</option>
                    </select>
                </div>

                <div class="col-md-3">
                    <button type="submit" class="btn btn-dark btn-lg w-100 fw-bold rounded-pill fs-6 shadow-sm transition">Tìm kiếm</button>
                </div>
            </form>
        </div>
    </div>

    <!-- DATA TABLE -->
    <div class="card shadow rounded-4 flex-grow-1 overflow-hidden border-0" style="box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.05) !important;">
        <div class="card-body p-0 position-relative">
            <div class="table-responsive" style="position: absolute; top: 0; bottom: 0; left: 0; right: 0; overflow-x: hidden;">
                <style>
                    .premium-table tbody tr {
                        transition: all 0.2s;
                        border-bottom: 1px solid #f1f5f9;
                    }
                    .premium-table tbody tr:hover {
                        background-color: #f8fafc !important;
                        transform: scale(1.002);
                    }
                    .premium-table th {
                        border-bottom: 2px solid #e2e8f0 !important;
                        color: #475569;
                        font-weight: 600;
                        text-transform: uppercase;
                        font-size: 0.85rem;
                        letter-spacing: 0.5px;
                    }
                    .product-img-wrapper {
                        width: 65px;
                        height: 65px;
                        padding: 4px;
                    }
                </style>
                <table class="table premium-table mb-0 w-100 align-middle">
                    <thead class="bg-white">
                        <tr>
                            <th class="py-4 ps-4 text-center" style="width: 5%; position: sticky; top: 0; z-index: 10; background: rgba(255,255,255,0.95); backdrop-filter: blur(8px);">STT</th>
                            <th class="py-4 text-center" style="width: 100px; position: sticky; top: 0; z-index: 10; background: rgba(255,255,255,0.95); backdrop-filter: blur(8px);">Hình</th>
                            <th class="py-4" style="position: sticky; top: 0; z-index: 10; background: rgba(255,255,255,0.95); backdrop-filter: blur(8px);">Tên Sản Phẩm</th>
                            <th class="py-4" style="position: sticky; top: 0; z-index: 10; background: rgba(255,255,255,0.95); backdrop-filter: blur(8px);">Danh Mục / Hãng</th>
                            <th class="py-4 text-end" style="position: sticky; top: 0; z-index: 10; background: rgba(255,255,255,0.95); backdrop-filter: blur(8px);">Giá Bán</th>
                            <th class="py-4 text-center" style="position: sticky; top: 0; z-index: 10; background: rgba(255,255,255,0.95); backdrop-filter: blur(8px);">Tồn Kho</th>
                            <th class="py-4 text-center pe-4" style="width: 150px; position: sticky; top: 0; z-index: 10; background: rgba(255,255,255,0.95); backdrop-filter: blur(8px);">Hành Động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            int stt = 1;
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="text-center text-secondary fw-medium ps-4">@(stt++)</td>
                                    <td class="text-center py-3">
                                        <div class="product-img-wrapper bg-white border rounded shadow-sm d-inline-flex align-items-center justify-content-center mx-auto overflow-hidden">
                                            <img src="@(string.IsNullOrEmpty(item.HinhAnh) ? "/images/no-image.png" : item.HinhAnh)"
                                                 style="max-width: 100%; max-height: 100%; object-fit: contain;"
                                                 alt="img" />
                                        </div>
                                    </td>
                                    <td class="py-4">
                                        <a asp-action="Details" asp-route-id="@item.MaSanPham" class="fw-bold text-dark text-decoration-none transition hover-primary fs-6 d-block">
                                            @item.TenSanPham
                                        </a>
                                        <small class="text-muted font-monospace">#ID: @item.MaSanPham.ToString("D4")</small>
                                    </td>
                                    <td>
                                        <div class="d-flex flex-column gap-1">
                                            <span class="badge bg-light text-primary border border-primary border-opacity-10 rounded-pill px-2 py-1 align-self-start fw-medium" style="font-size: 0.75rem;">
                                                <i class="fa-solid fa-layer-group me-1 opacity-50"></i> @(item.MaDanhMucNavigation?.TenDanhMuc ?? "N/A")
                                            </span>
                                            <span class="badge bg-light text-primary border border-primary border-opacity-10 rounded-pill px-2 py-1 align-self-start fw-medium" style="font-size: 0.75rem;">
                                                <i class="fa-solid fa-industry me-1 opacity-50"></i> @(string.IsNullOrEmpty(item.HangSanXuat) ? "N/A" : item.HangSanXuat)
                                            </span>
                                        </div>
                                    </td>
                                    <td class="text-end fw-bold text-danger fs-6">
                                        @item.GiaBan.ToString("N0") <small>VNĐ</small>
                                    </td>
                                    <td class="text-center">
                                        @if (item.SoLuongTon > 0)
                                        {
                                            <div class="d-inline-flex flex-column align-items-center">
                                                <span class="badge rounded-pill bg-success bg-opacity-10 text-success px-3 py-2 fw-bold" style="min-width: 50px;">
                                                    @item.SoLuongTon
                                                </span>
                                                <small class="text-success mt-1 fw-medium" style="font-size: 0.65rem;">CÒN HÀNG</small>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="d-inline-flex flex-column align-items-center">
                                                <span class="badge rounded-pill bg-danger bg-opacity-10 text-danger px-3 py-2 fw-bold" style="min-width: 50px;">
                                                    0
                                                </span>
                                                <small class="text-danger mt-1 fw-medium" style="font-size: 0.65rem;">HẾT HÀNG</small>
                                            </div>
                                        }
                                    </td>
                                    <td class="text-center pe-4">
                                        <div class="d-inline-flex gap-2">
                                            <a asp-action="Details" asp-route-id="@item.MaSanPham" class="btn btn-sm btn-light border text-info rounded-circle d-inline-flex align-items-center justify-content-center transition shadow-xs" style="width: 35px; height: 35px;" title="Xem chi tiết">
                                                <i class="fa-solid fa-eye"></i>
                                            </a>
                                            @if (User.IsInRole("Quản trị viên") || User.IsInRole("Admin") || User.IsInRole("Nhân viên kho"))
                                            {
                                                <a asp-action="Edit" asp-route-id="@item.MaSanPham" class="btn btn-sm btn-light border text-warning rounded-circle d-inline-flex align-items-center justify-content-center transition shadow-xs" style="width: 35px; height: 35px;" title="Sửa">
                                                    <i class="fa-solid fa-pen"></i>
                                                </a>
                                                <a asp-action="Delete" asp-route-id="@item.MaSanPham" class="btn btn-sm btn-light border text-danger rounded-circle d-inline-flex align-items-center justify-content-center transition shadow-xs" style="width: 35px; height: 35px;" title="Xóa">
                                                    <i class="fa-solid fa-trash"></i>
                                                </a>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted py-5">
                                    <div class="py-4">
                                        <i class="fa-solid fa-box-open fa-3x mb-3 text-secondary opacity-25"></i>
                                        <p class="fs-5 fw-medium mb-1">Không tìm thấy sản phẩm nào</p>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>