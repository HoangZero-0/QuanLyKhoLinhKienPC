@model IEnumerable<QuanLyKhoLinhKienPC.Models.SanPham>

@{
    ViewData["Title"] = "Quản Lý Sản Phẩm";
}

<div class="d-flex flex-column h-100">

    <div class="d-flex justify-content-between align-items-center mb-3 flex-shrink-0">
        <h2 class="text-primary m-0"><i class="fa-solid fa-box-open"></i> Quản Lý Sản Phẩm</h2>
        @if (User.IsInRole("Quản trị viên") || User.IsInRole("Admin") || User.IsInRole("Nhân viên kho"))
        {
            <div>
                <a asp-action="Trash" class="btn btn-outline-danger shadow-sm me-2" title="Thùng rác">
                    <i class="fa-solid fa-trash-can"></i>
                </a>
                <a asp-action="Create" class="btn btn-success shadow-sm">
                    <i class="fa-solid fa-plus"></i> Thêm sản phẩm
                </a>
            </div>
        }
    </div>


    <div class="card mb-3 shadow-sm flex-shrink-0 border-0">
        <div class="card-body py-2">
            <form asp-action="Index" method="get" class="row g-2 align-items-center">

                <div class="col-md-6">
                    <div class="input-group">
                        <span class="input-group-text bg-white text-muted border-end-0"><i class="fa-solid fa-magnifying-glass"></i></span>
                        <input type="text" name="searchString" class="form-control border-start-0 ps-0"
                               placeholder="Nhập tên sản phẩm để tìm kiếm..." value="@ViewData["CurrentFilter"]">
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="input-group">
                        <span class="input-group-text bg-white text-muted"><i class="fa-solid fa-filter"></i></span>
                        <select name="MaDanhMuc" class="form-select" asp-items="ViewBag.MaDanhMuc" onchange="this.form.submit()">
                            <option value="">-- Tất cả danh mục --</option>
                        </select>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="input-group">
                        <span class="input-group-text bg-white text-muted"><i class="fa-solid fa-industry"></i></span>
                        <select name="HangSanXuat" class="form-select" asp-items="ViewBag.HangSanXuatList" onchange="this.form.submit()">
                            <option value="">-- Tất cả hãng --</option>
                        </select>
                    </div>
                </div>

                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100 fw-bold">Tìm kiếm</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm flex-grow-1 overflow-hidden border-0">
        <div class="card-body p-0 position-relative">
            <div class="table-responsive" style="position: absolute; top: 0; bottom: 0; left: 0; right: 0;">
                <table class="table table-striped table-hover mb-0 w-100 align-middle">
                    <thead class="table-primary">
                        <tr>
                            <th class="py-3 ps-3 text-center" style="width: 5%; position: sticky; top: 0; z-index: 10;">STT</th>
                            <th class="py-3 ps-3 text-center" style="width: 80px; position: sticky; top: 0; z-index: 10;">Hình</th>
                            <th class="py-3" style="position: sticky; top: 0; z-index: 10;">Tên sản phẩm</th>
                            <th class="py-3" style="position: sticky; top: 0; z-index: 10;">Danh mục</th>
                            <th class="py-3" style="position: sticky; top: 0; z-index: 10;">Hãng sản xuất</th>
                            <th class="py-3 text-end" style="position: sticky; top: 0; z-index: 10;">Giá bán</th>
                            <th class="py-3 text-center" style="position: sticky; top: 0; z-index: 10;">Tồn kho</th>
                            <th class="py-3 text-center" style="width: 150px; position: sticky; top: 0; z-index: 10;">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            int stt = 1;
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="text-center text-muted fw-bold align-middle">@(stt++)</td>
                                    <td class="text-center py-2 align-middle">
                                        <div class="bg-white border rounded p-1 d-inline-block shadow-sm">
                                            <img src="@(string.IsNullOrEmpty(item.HinhAnh) ? "/images/no-image.png" : item.HinhAnh)"
                                                 style="width: 60px; height: 60px; object-fit: contain;"
                                                 alt="Img" />
                                        </div>
                                    </td>

                                    <td class="fw-bold text-primary">
                                        <a asp-action="Details" asp-route-id="@item.MaSanPham" class="text-decoration-none">
                                            @Html.DisplayFor(modelItem => item.TenSanPham)
                                        </a>
                                    </td>

                                    <td>
                                        <span class="badge bg-light text-dark border">
                                            @(item.MaDanhMucNavigation?.TenDanhMuc ?? "N/A")
                                        </span>
                                    </td>

                                    <td>
                                        <span class="text-muted">
                                            @(string.IsNullOrEmpty(item.HangSanXuat) ? "N/A" : item.HangSanXuat)
                                        </span>
                                    </td>

                                    <td class="text-end fw-bold text-danger">
                                        @item.GiaBan.ToString("N0") VNĐ
                                    </td>

                                    <td class="text-center">
                                        @if (item.SoLuongTon > 0)
                                        {
                                            <span class="badge bg-success rounded-pill">@item.SoLuongTon</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger rounded-pill">Hết hàng</span>
                                        }
                                    </td>

                                    <td class="text-center py-2">
                                        <a asp-action="Details" asp-route-id="@item.MaSanPham" class="btn btn-sm btn-info text-white" title="Xem chi tiết">
                                            <i class="fa-solid fa-eye"></i>
                                        </a>

                                        @if (User.IsInRole("Quản trị viên") || User.IsInRole("Admin") || User.IsInRole("Nhân viên kho"))
                                        {
                                            <a asp-action="Edit" asp-route-id="@item.MaSanPham" class="btn btn-sm btn-warning text-dark" title="Sửa">
                                                <i class="fa-solid fa-pen"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.MaSanPham" class="btn btn-sm btn-danger" title="Xóa">
                                                <i class="fa-solid fa-trash"></i>
                                            </a>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center text-muted py-5">
                                    <i class="fa-solid fa-box-open fa-3x mb-3 text-secondary opacity-50"></i><br>
                                    Không tìm thấy sản phẩm nào.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>