@model IEnumerable<QuanLyKhoLinhKienPC.Models.SanPham>

@{
    ViewData["Title"] = "Thùng Rác Sản Phẩm";
}

<div class="d-flex flex-column h-100">

    <div class="d-flex justify-content-between align-items-center mb-3 flex-shrink-0">
        <h2 class="text-danger m-0"><i class="fa-solid fa-trash-can"></i> Thùng Rác Sản Phẩm</h2>
        <div>
            @if (Model != null && Model.Any() && (User.IsInRole("Quản trị viên") || User.IsInRole("Admin")))
            {
                <form asp-action="EmptyTrash" method="post" class="d-inline" data-confirm="Bạn có chắc chắn muốn DỌN SẠCH toàn bộ thùng rác?\nDữ liệu sẽ bị xóa vĩnh viễn và không thể khôi phục!">
                    <button type="submit" class="btn btn-danger shadow-sm">
                        <i class="fa-solid fa-fire"></i> Dọn sạch thùng rác
                    </button>
                </form>
            }
            <a asp-action="Index" class="btn btn-secondary shadow-sm me-2">
                <i class="fa-solid fa-arrow-left"></i> Quay lại
            </a>
        </div>
    </div>


    <div class="card mb-3 shadow-sm flex-shrink-0 border-0">
        <div class="card-body py-2">
            <form asp-action="Trash" method="get" class="row g-2 align-items-center">
                <div class="col-md-6">
                    <div class="input-group">
                        <span class="input-group-text bg-white text-muted border-end-0"><i class="fa-solid fa-magnifying-glass"></i></span>
                        <input type="text" name="searchString" class="form-control border-start-0 ps-0" placeholder="Tìm kiếm tên sản phẩm..." value="@ViewData["CurrentFilter"]">
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="input-group">
                        <span class="input-group-text bg-white text-muted"><i class="fa-solid fa-filter"></i></span>
                        <select name="MaDanhMuc" class="form-select" asp-items="ViewBag.MaDanhMuc" onchange="this.form.submit()">
                            <option value="">-- Tất cả danh mục --</option>
                        </select>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="input-group">
                        <span class="input-group-text bg-white text-muted"><i class="fa-solid fa-industry"></i></span>
                        <select name="HangSanXuat" class="form-select" asp-items="ViewBag.HangSanXuatList" onchange="this.form.submit()">
                            <option value="">-- Tất cả hãng --</option>
                        </select>
                    </div>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-danger w-100 fw-bold">Tìm kiếm</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm flex-grow-1 overflow-hidden border-0">
        <div class="card-body p-0 position-relative">
            <div class="table-responsive" style="position: absolute; top: 0; bottom: 0; left: 0; right: 0;">
                <table class="table table-striped table-hover mb-0 w-100 align-middle">
                    <thead class="table-danger">
                        <tr>
                            <th class="py-3 ps-3 text-center" style="width: 80px; position: sticky; top: 0; z-index: 10;">Hình</th>
                            <th class="py-3" style="position: sticky; top: 0; z-index: 10;">Tên sản phẩm</th>
                            <th class="py-3" style="position: sticky; top: 0; z-index: 10;">Danh mục</th>
                            <th class="py-3" style="position: sticky; top: 0; z-index: 10;">Hãng sản xuất</th>
                            <th class="py-3 text-end" style="position: sticky; top: 0; z-index: 10;">Giá bán</th>
                            <th class="text-center py-3" style="width: 150px; position: sticky; top: 0; z-index: 10;">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="text-center py-2">
                                        <img src="@(string.IsNullOrEmpty(item.HinhAnh) ? "/images/no-image.png" : item.HinhAnh)"
                                             class="rounded border bg-white" style="width: 50px; height: 50px; object-fit: contain;"
                                             alt="Img" />
                                    </td>
                                    <td class="fw-bold">@Html.DisplayFor(modelItem => item.TenSanPham)</td>
                                    <td>
                                        <span class="badge bg-light text-dark border">
                                            @(item.MaDanhMucNavigation?.TenDanhMuc ?? "N/A")
                                        </span>
                                    </td>
                                    <td>
                                        <span class="text-muted">
                                            @(string.IsNullOrEmpty(item.HangSanXuat) ? "N/A" : item.HangSanXuat)
                                        </span>
                                    </td>
                                    <td class="text-end text-danger fw-bold">
                                        @item.GiaBan.ToString("N0") VNĐ
                                    </td>
                                    <td class="text-center py-2">
                                        <form asp-action="Restore" asp-route-id="@item.MaSanPham" method="post" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-success" title="Khôi phục">
                                                <i class="fa-solid fa-rotate-left"></i>
                                            </button>
                                        </form>

                                        @if (User.IsInRole("Quản trị viên") || User.IsInRole("Admin"))
                                        {
                                            <form asp-action="DeleteForce" asp-route-id="@item.MaSanPham" method="post" class="d-inline" data-confirm="CẢNH BÁO: Xóa vĩnh viễn sản phẩm này không thể lấy lại. Bạn chắc chứ?">
                                                <button type="submit" class="btn btn-sm btn-dark" title="Xóa vĩnh viễn">
                                                    <i class="fa-solid fa-ban"></i>
                                                </button>
                                            </form>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-5">
                                    <i class="fa-regular fa-trash-can fa-3x mb-3 text-secondary opacity-50"></i><br>
                                    Thùng rác trống.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
    </div>
</div>