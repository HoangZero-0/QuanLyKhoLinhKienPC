@model QuanLyKhoLinhKienPC.Models.SanPham

@{
    ViewData["Title"] = "Chi Tiết Sản Phẩm";
}

<div class="d-flex flex-column pt-4 pb-5">
    <!-- HEADER (đồng bộ với Index: text-primary, không card riêng) -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-info m-0"><i class="fa-solid fa-eye me-1"></i> Chi Tiết Sản Phẩm</h2>
        <div class="d-flex gap-2">
            @if (User.IsInRole("Quản trị viên") || User.IsInRole("Admin") || User.IsInRole("Nhân viên kho"))
            {
                <a asp-action="Edit" asp-route-id="@Model.MaSanPham" class="btn btn-warning shadow-sm rounded-pill px-4 fw-bold transition">
                    <i class="fa-solid fa-pen-to-square me-1"></i> Chỉnh sửa
                </a>
            }
            <a asp-action="Index" class="btn btn-light border shadow-sm rounded-pill px-4 fw-semibold text-secondary transition">
                <i class="fa-solid fa-arrow-left me-1"></i> Quay lại
            </a>
        </div>
    </div>

    <!-- ═══════════════════════════════════════════════════════════
         TẦNG 1: HERO SECTION — Thông tin nhận diện (cứng, không đổi)
         ═══════════════════════════════════════════════════════════ -->
    <div class="card shadow rounded-4 border-0 mb-4 detail-card">
        <div class="card-body p-4">
            <div class="row g-4 align-items-center">
                <!-- Ảnh sản phẩm -->
                <div class="col-lg-4 col-md-5 text-center">
                    <div class="bg-light rounded-4 p-3 d-flex align-items-center justify-content-center border" style="height: 350px;">
                        <img src="@(string.IsNullOrEmpty(Model.HinhAnh) ? "/images/no-image.png" : Model.HinhAnh)"
                             alt="@Model.TenSanPham"
                             class="img-fluid rounded transition hover-zoom"
                             style="max-height: 100%; object-fit: contain;" />
                    </div>
                    <div class="mt-3">
                        <small class="text-muted text-uppercase d-block mb-1" style="font-size: 0.7rem; letter-spacing: 1px;">Mã hệ thống</small>
                        <span class="badge bg-light text-dark border px-3 py-2 fw-bold font-monospace rounded-pill" style="letter-spacing: 0.5px;">
                            #PRD-@Model.MaSanPham.ToString("D4")
                        </span>
                    </div>
                </div>

                <!-- Thông tin cơ bản -->
                <div class="col-lg-8 col-md-7">
                    <!-- Tên + Giá -->
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div class="flex-grow-1 pe-4">
                            <h3 class="fw-bold text-dark mb-2">@Model.TenSanPham</h3>
                            <div class="d-flex flex-wrap gap-2">
                                <span class="badge rounded-pill bg-light text-primary px-3 py-2 border border-primary border-opacity-10 fw-semibold">
                                    <i class="fa-solid fa-layer-group me-1 opacity-50"></i> @(Model.MaDanhMucNavigation?.TenDanhMuc ?? "Chưa phân loại")
                                </span>
                                <span class="badge rounded-pill bg-light text-primary px-3 py-2 border border-primary border-opacity-10 fw-semibold">
                                    <i class="fa-solid fa-industry me-1 opacity-50"></i> @(string.IsNullOrEmpty(Model.HangSanXuat) ? "N/A" : Model.HangSanXuat)
                                </span>
                            </div>
                        </div>
                        <div class="text-end" style="white-space: nowrap;">
                            <span class="text-danger fw-bold" style="font-size: 1.8rem;">@Model.GiaBan.ToString("N0")</span>
                            <span class="text-danger fw-bold fs-5 ms-1">VNĐ</span>
                            <div class="text-muted small">Giá niêm yết chính thức</div>
                        </div>
                    </div>

                    <!-- Tồn kho + Bảo hành -->
                    <div class="row g-3 mt-1">
                        <div class="col-sm-6">
                            <div class="d-flex align-items-center p-3 rounded-3 bg-light border">
                                <i class="fa-solid fa-boxes-stacked text-success fs-4 me-3"></i>
                                <div>
                                    <small class="text-muted d-block">Tồn kho hiện tại</small>
                                    <span class="fw-bold text-success fs-5">@(Model.SoLuongTon > 0 ? Model.SoLuongTon + " sản phẩm" : "Hết hàng")</span>
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="d-flex align-items-center p-3 rounded-3 bg-light border h-100">
                                <i class="fa-solid fa-shield-halved text-success fs-4 me-3"></i>
                                <div>
                                    <small class="text-muted d-block">Bảo hành chính hãng</small>
                                    <span class="fw-bold text-success fs-5">@Model.ThoiGianBaoHanh tháng</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ═══════════════════════════════════════════════════════════
         TẦNG 2: THÔNG SỐ KỸ THUẬT (co giãn tự do theo dữ liệu)
         ═══════════════════════════════════════════════════════════ -->
    <div class="card shadow rounded-4 border-0 mb-4 detail-card">
        <div class="card-header bg-white py-3 px-4 border-bottom border-light">
            <h5 class="mb-0 text-dark fw-bold"><i class="fa-solid fa-clipboard-list text-info me-2"></i>Thông Số Kỹ Thuật</h5>
        </div>
        <div class="card-body p-0">
            <table class="table mb-0">
                <tbody>
                    @if (!string.IsNullOrEmpty(Model.ThongSoKyThuat))
                    {
                        var lines = Model.ThongSoKyThuat.Split(new[] { "\r\n", "\r", "\n" }, StringSplitOptions.RemoveEmptyEntries);
                        foreach (var line in lines)
                        {
                            var parts = line.Split(':', 2);
                            if (parts.Length == 2)
                            {
                                <tr>
                                    <td class="bg-light text-secondary fw-semibold py-3 ps-4 border-end" style="width: 33.33%;">@parts[0].Trim()</td>
                                    <td class="ps-4 text-dark py-3">@parts[1].Trim()</td>
                                </tr>
                            }
                            else
                            {
                                <tr>
                                    <td colspan="2" class="ps-4 text-dark py-3">@line</td>
                                </tr>
                            }
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="2" class="text-center text-muted py-5">Sản phẩm chưa cập nhật thông số kỹ thuật.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- ═══════════════════════════════════════════════════════════
         TẦNG 3: DANH SÁCH SERI TRONG KHO (cố định chiều cao, cuộn dọc)
         ═══════════════════════════════════════════════════════════ -->
    <div class="card shadow rounded-4 border-0 detail-card">
        <div class="card-header bg-white py-3 px-4 border-bottom border-light d-flex justify-content-between align-items-center">
            <h5 class="mb-0 text-dark fw-bold"><i class="fa-solid fa-barcode text-info me-2"></i>Danh Sách Số Seri Trong Kho</h5>
            <div class="position-relative" style="width: 280px;">
                <i class="fa-solid fa-magnifying-glass position-absolute top-50 translate-middle-y ms-3 text-muted"></i>
                <input type="text" id="filterSeri" class="form-control rounded-pill ps-5 py-2 border bg-light" placeholder="Tìm số seri..." style="font-size: 0.85rem;">
            </div>
        </div>

        <div class="card-body p-0">
            <div class="seri-scroll-area" style="max-height: 500px; overflow-y: auto;">
                <table class="table table-hover mb-0 align-middle" id="seriTable">
                    <thead class="bg-light sticky-top" style="z-index: 5;">
                        <tr>
                            <th class="text-center py-3 ps-4 text-secondary" style="width: 80px;">STT</th>
                            <th class="py-3 text-dark">Mã Seri Number</th>
                            <th class="py-3 text-dark pe-4 text-start" style="width: 66.67%;">Thời Gian Nhập</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            var seriInStock = Model.SeriSanPham?.Where(s => s.TrangThai == 1).OrderByDescending(s => s.MaSeri).ToList();
                            if (seriInStock != null && seriInStock.Any())
                            {
                                int i = 1;
                                foreach (var seri in seriInStock)
                                {
                                    <tr class="seri-row">
                                        <td class="text-center text-muted ps-4">@i</td>
                                        <td>
                                            <span class="fw-bold text-dark px-2 py-1 bg-light rounded font-monospace" style="font-size: 0.85rem;">
                                                @seri.SoSeri
                                            </span>
                                        </td>
                                        <td class="text-muted small pe-4 text-start">
                                            <i class="fa-regular fa-calendar me-1"></i>
                                            @(seri.MaPhieuNhapNavigation?.NgayNhap.ToString("dd/MM/yyyy HH:mm") ?? "N/A")
                                        </td>
                                    </tr>
                                    i++;
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="3" class="text-center text-muted py-5">
                                        <i class="fa-solid fa-box-open fa-2x mb-2 d-block opacity-25"></i>
                                        Hiện không có Seri nào đang tồn kho.
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card-footer bg-white py-3 px-4 border-top d-flex justify-content-between align-items-center">
            <span class="text-muted small"><i class="fa-regular fa-clock me-1"></i> Cập nhật lúc: @DateTime.Now.ToString("HH:mm dd/MM/yyyy")</span>
            <span class="badge bg-light text-dark border py-2 px-3 rounded-pill fw-normal">
                Tổng tồn kho: <strong class="text-primary">@(seriInStock?.Count ?? 0)</strong> Seri
            </span>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $("#filterSeri").on("keyup", function () {
                var value = $(this).val().toLowerCase();
                $("#seriTable .seri-row").filter(function () {
                    $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1)
                });
            });
        });
    </script>
}

<style>
    /* Card chung */
    .detail-card { box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.05) !important; }

    /* Transition & Interaction */
    .transition { transition: all 0.2s ease; }
    .hover-zoom:hover { transform: scale(1.03); }

    /* Table hover */
    .table-hover tbody tr { transition: background 0.15s; }

    /* Font */
    .font-monospace { font-family: 'JetBrains Mono', 'Roboto Mono', monospace; }

    /* Custom scrollbar */
    .seri-scroll-area::-webkit-scrollbar { width: 6px; }
    .seri-scroll-area::-webkit-scrollbar-thumb { background: #d1d5db; border-radius: 10px; }
    .seri-scroll-area::-webkit-scrollbar-track { background: transparent; }

    /* Responsive: bỏ sticky ảnh trên mobile */
    @@media (max-width: 767.98px) {
        .sticky-top { position: static !important; }
    }
</style>