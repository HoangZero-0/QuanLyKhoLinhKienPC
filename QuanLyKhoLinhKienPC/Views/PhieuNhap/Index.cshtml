@model IEnumerable<QuanLyKhoLinhKienPC.Models.PhieuNhap>

@{
    ViewData["Title"] = "Lịch Sử Nhập Kho";
}

<div class="d-flex flex-column h-100">
    <div class="d-flex justify-content-between align-items-center mb-3 flex-shrink-0">
        <h2 class="text-primary m-0"><i class="fa-solid fa-clock-rotate-left"></i> Lịch Sử Lập Phiếu Nhập</h2>
        @if (User.IsInRole("Quản trị viên") || User.IsInRole("Admin") || User.IsInRole("Nhân viên kho"))
        {
            <div>
                <a asp-action="Create" class="btn btn-primary shadow-sm fw-bold">
                    <i class="fa-solid fa-plus"></i> Tạo Phiếu Nhập Mới
                </a>
                <a asp-action="Trash" class="btn btn-secondary shadow-sm fw-bold ms-2">
                    <i class="fa-solid fa-trash-can"></i> Thùng Rác
                </a>
            </div>
        }
    </div>

    <div class="card shadow-sm flex-grow-1 overflow-hidden border-0">
        <div class="card-body p-0 position-relative">
            <div class="table-responsive" style="position: absolute; top: 0; bottom: 0; left: 0; right: 0;">
                <table class="table table-striped table-hover mb-0 w-100 align-middle">
                    <thead class="table-primary">
                        <tr>
                            <th class="py-3 text-center" style="width: 5%; position: sticky; top: 0; z-index: 10;">STT</th>
                            <th class="py-3 ps-4" style="position: sticky; top: 0; z-index: 10;">Mã Phiếu</th>
                            <th class="py-3" style="position: sticky; top: 0; z-index: 10;">Ngày Lập</th>
                            <th class="py-3" style="position: sticky; top: 0; z-index: 10;">Nhà Cung Cấp</th>
                            <th class="py-3" style="position: sticky; top: 0; z-index: 10;">Người Lập</th>
                            <th class="py-3 text-end" style="position: sticky; top: 0; z-index: 10;">Tổng Tiền (VNĐ)</th>
                            <th class="py-3" style="position: sticky; top: 0; z-index: 10;">Ghi Chú</th>
                            <th class="py-3 text-center pe-4" style="position: sticky; top: 0; z-index: 10;">Thao Tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="8" class="text-center text-muted fst-italic py-4">Chưa có phiếu nhập nào trong hệ thống.</td>
                            </tr>
                        }
                        else
                        {
                            int stt = 1;
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="text-center text-muted fw-bold align-middle">@(stt++)</td>
                                    <td class="ps-4 fw-bold text-primary align-middle">
                                        #PN-@item.MaPhieuNhap.ToString("D5")
                                    </td>
                                    <td>
                                        <span class="badge bg-light text-dark border">
                                            <i class="fa-regular fa-calendar"></i> @item.NgayNhap.ToString("dd/MM/yyyy HH:mm")
                                        </span>
                                    </td>
                                    <td class="fw-bold">
                                        @item.MaNhaCungCapNavigation?.TenNhaCungCap
                                    </td>
                                    <td>
                                        <i class="fa-solid fa-user-tie text-muted"></i> @(item.MaNguoiDungNavigation?.HoTen ?? "Hệ thống")
                                    </td>
                                    <td class="text-end fw-bold text-danger">
                                        @string.Format("{0:N0}", item.TongTien) đ
                                    </td>
                                    <td class="text-truncate" style="max-width: 150px;" title="@item.GhiChu">
                                        @(string.IsNullOrEmpty(item.GhiChu) ? "-" : item.GhiChu)
                                    </td>
                                    <td class="text-center pe-4">
                                        <a asp-action="Details" asp-route-id="@item.MaPhieuNhap" class="btn btn-sm btn-info text-white shadow-sm" title="Xem Hóa Đơn">
                                            <i class="fa-solid fa-eye"></i> Chi Tiết
                                        </a>
                                        @if (User.IsInRole("Quản trị viên") || User.IsInRole("Admin") || User.IsInRole("Nhân viên kho"))
                                        {
                                            <a asp-action="Delete" asp-route-id="@item.MaPhieuNhap" class="btn btn-sm btn-danger text-white shadow-sm ms-1" title="Xóa vào thùng rác">
                                                <i class="fa-solid fa-trash"></i> Xóa
                                            </a>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
