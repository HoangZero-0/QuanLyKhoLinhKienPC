@model IEnumerable<QuanLyKhoLinhKienPC.Models.PhieuNhap>

@{
    ViewData["Title"] = "Thùng Rác Phiếu Nhập";
}

<div class="container-fluid pt-4 h-100 overflow-y-auto">
    <div class="row mb-3 align-items-center">
        <div class="col-md-6">
            <h3 class="text-secondary fw-bold"><i class="fa-solid fa-trash-can"></i> Thùng Rác Phiếu Nhập</h3>
        </div>
        <div class="col-md-6 text-end">
            @if (User.IsInRole("Quản trị viên") || User.IsInRole("Admin"))
            {

            }
            <a asp-action="Index" class="btn btn-secondary shadow-sm fw-bold ms-2">
                <i class="fa-solid fa-arrow-left"></i> Quay lại
            </a>
        </div>
    </div>

    <div class="card shadow border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped align-middle mb-0">
                    <thead class="table-secondary">
                        <tr>
                            <th class="ps-4">Mã Phiếu Nhập</th>
                            <th>Ngày Lập</th>
                            <th>Nhà Cung Cấp</th>
                            <th>Người Lập</th>
                            <th class="text-end">Tổng Tiền (VNĐ)</th>
                            <th class="text-center pe-4">Thao Tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted fst-italic py-4">
                                    <i class="fa-solid fa-box-open fa-2x mb-3 text-secondary"></i><br />
                                    Thùng rác đang trống.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold text-secondary">
                                        #PN-@item.MaPhieuNhap.ToString("D5")
                                    </td>
                                    <td>
                                        <span class="badge bg-light text-dark border">
                                            <i class="fa-regular fa-calendar"></i> @item.NgayNhap.ToString("dd/MM/yyyy HH:mm")
                                        </span>
                                    </td>
                                    <td class="fw-bold text-muted">@item.MaNhaCungCapNavigation?.TenNhaCungCap</td>
                                    <td class="text-muted"><i class="fa-solid fa-user-tie"></i> @(item.MaNguoiDungNavigation?.HoTen ?? "Hệ thống")</td>
                                    <td class="text-end fw-bold text-muted">
                                        <del>@string.Format("{0:N0}", item.TongTien) đ</del>
                                    </td>
                                    <td class="text-center pe-4">
                                        <form asp-action="Restore" asp-route-id="@item.MaPhieuNhap" method="post" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-success text-white shadow-sm" title="Khôi phục">
                                                <i class="fa-solid fa-trash-arrow-up"></i> Khôi phục
                                            </button>
                                        </form>
                                        
                                        @if (User.IsInRole("Quản trị viên") || User.IsInRole("Admin"))
                                        {

                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
