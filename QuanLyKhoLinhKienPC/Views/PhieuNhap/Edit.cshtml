@model QuanLyKhoLinhKienPC.Models.PhieuNhap

@{
    ViewData["Title"] = "Chỉnh Sửa Phiếu Nhập";
}

<div class="container-fluid pt-4 pb-5">
    <div class="row justify-content-center">
        <div class="col-xl-6 col-lg-7">
            <div class="card shadow rounded-4 border-0" style="box-shadow: 0 15px 35px -5px rgb(0 0 0 / 0.05) !important;">
                <div class="card-header bg-white border-bottom border-light py-4 px-4 d-flex justify-content-between align-items-center">
                    <div>
                        <h4 class="mb-1 text-primary fw-bold"><i class="fa-solid fa-pen-to-square me-2"></i> Chỉnh Sửa Phiếu Nhập</h4>
                        <p class="text-muted small mb-0">Mã định danh: <strong class="text-dark font-monospace">#PN-@Model.MaPhieuNhap.ToString("D5")</strong></p>
                    </div>
                </div>
                <div class="card-body p-4 p-md-5">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-4 border-0 shadow-sm py-2 mb-4" role="alert"></div>
                        
                        <input type="hidden" asp-for="MaPhieuNhap" />
                        <input type="hidden" asp-for="NgayNhap" />
                        <input type="hidden" asp-for="MaNguoiDung" />
                        <input type="hidden" asp-for="IsDeleted" />

                        <div class="row g-4">
                            <!-- Nhà Cung Cấp -->
                            <div class="col-12">
                                <label asp-for="MaNhaCungCap" class="form-label fw-bold text-secondary small text-uppercase ms-1">Nhà Cung Cấp <span class="text-danger">*</span></label>
                                <div class="input-group input-group-lg">
                                    <span class="input-group-text bg-light border-end-0 rounded-start-pill ps-3 text-muted"><i class="fa-solid fa-truck"></i></span>
                                    <select asp-for="MaNhaCungCap" class="form-select border-start-0 rounded-end-pill fs-6 transition shadow-xs" asp-items="ViewBag.MaNhaCungCap"></select>
                                </div>
                                <span asp-validation-for="MaNhaCungCap" class="text-danger small ms-1"></span>
                            </div>

                            <!-- Tổng Tiền -->
                            <div class="col-12">
                                <label asp-for="TongTien" class="form-label fw-bold text-secondary small text-uppercase ms-1">Tổng Giá Trị Phiếu</label>
                                <div class="input-group input-group-lg">
                                    <span class="input-group-text bg-light border-end-0 rounded-start-pill ps-3 text-muted"><i class="fa-solid fa-money-bill-wave"></i></span>
                                    <input asp-for="TongTien" class="form-control border-start-0 fs-6 bg-light fw-bold text-danger" readonly />
                                    <span class="input-group-text bg-light border-start-0 rounded-end-pill pe-3 text-muted fw-bold">VNĐ</span>
                                </div>
                                <div class="text-muted small ms-1 mt-1"><i class="fa-solid fa-circle-info me-1"></i> Giá trị này được tính tự động dựa trên chi tiết sản phẩm.</div>
                            </div>

                            <!-- Ghi Chú -->
                            <div class="col-12">
                                <label asp-for="GhiChu" class="form-label fw-bold text-secondary small text-uppercase ms-1">Ghi Chú / Nội dung chỉnh sửa</label>
                                <textarea asp-for="GhiChu" class="form-control rounded-4 border transition p-3 shadow-xs" rows="4" placeholder="Nhập lý do chỉnh sửa hoặc ghi chú thêm..."></textarea>
                                <span asp-validation-for="GhiChu" class="text-danger small ms-1"></span>
                            </div>
                        </div>

                        <div class="mt-5 pt-3 border-top d-flex justify-content-between align-items-center">
                            <a asp-action="Index" class="btn btn-light border rounded-pill px-4 fw-medium transition text-secondary">
                                <i class="fa-solid fa-arrow-left me-1"></i> Quay lại
                            </a>
                            <button type="submit" class="btn btn-primary shadow-lg rounded-pill px-5 fw-bold transition py-2 btn-lg">
                                <i class="fa-solid fa-save me-2"></i> LƯU THAY ĐỔI
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- INFO SIDEBAR (Matching SanPham style) -->
        <div class="col-xl-4 col-lg-5 d-none d-lg-block">
            <div class="card shadow rounded-4 border-0 bg-primary bg-opacity-10 mb-4 border-start border-primary border-5">
                <div class="card-body p-4">
                    <h6 class="text-uppercase text-primary fw-bold mb-3 small"><i class="fa-solid fa-info-circle me-2"></i>Hướng dẫn chỉnh sửa</h6>
                    <ul class="text-primary small mb-0 ps-3">
                        <li class="mb-2">Bạn có thể thay đổi Nhà cung cấp nếu có sai sót khi nhập.</li>
                        <li class="mb-2">Ghi chú nên được cập nhật để ghi lại lý do sửa đổi phiếu nhập.</li>
                        <li>Thông tin ngày nhập và người nhập được giữ nguyên để đảm bảo tính minh bạch.</li>
                    </ul>
                </div>
            </div>
            
            <div class="card shadow rounded-4 border-0 overflow-hidden">
                <div class="card-header bg-white py-3 border-bottom border-light">
                    <h6 class="mb-0 fw-bold text-dark small text-uppercase"><i class="fa-solid fa-clock-rotate-left me-2 text-muted"></i>Lịch sử phiếu</h6>
                </div>
                <div class="card-body p-4">
                    <div class="d-flex mb-3">
                        <div class="flex-shrink-0 text-center" style="width: 40px;">
                            <i class="fa-solid fa-calendar-check text-success"></i>
                        </div>
                        <div class="ms-2">
                            <div class="fw-bold small">Ngày khởi tạo</div>
                            <div class="text-muted small">@Model.NgayNhap.ToString("dd/MM/yyyy HH:mm")</div>
                        </div>
                    </div>
                    <div class="d-flex">
                        <div class="flex-shrink-0 text-center" style="width: 40px;">
                            <i class="fa-solid fa-user-edit text-info"></i>
                        </div>
                        <div class="ms-2">
                            <div class="fw-bold small">Người thực hiện</div>
                            <div class="text-muted small">@(Model.MaNguoiDungNavigation?.HoTen ?? "N/A")</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .transition { transition: all 0.2s ease; }
    .shadow-xs { box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05); }
    .font-monospace { font-family: 'JetBrains Mono', 'Roboto Mono', monospace; }
    .form-select-lg { font-size: 1rem !important; }
</style>
