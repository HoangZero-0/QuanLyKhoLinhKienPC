@model QuanLyKhoLinhKienPC.Models.PhieuNhap

@{
    ViewData["Title"] = "Cập Nhật Phiếu Nhập";
}

<style>
    .transition { transition: all 0.2s ease; }
    .shadow-xs { box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05); }
    .shadow-inner { box-shadow: inset 0 2px 4px 0 rgba(0, 0, 0, 0.05); }
    .font-monospace { font-family: 'JetBrains Mono', 'Roboto Mono', monospace; }
</style>

<div class="container-fluid pt-2">
    <div class="row justify-content-center">
        <div class="col-xl-10">
            <div class="card shadow rounded-4 border-0 mb-4" style="box-shadow: 0 15px 30px -5px rgb(0 0 0 / 0.05) !important;">
                <div class="card-header bg-warning bg-opacity-10 py-3 border-bottom-0">
                    <h4 class="mb-0 text-warning fw-bold"><i class="fa-solid fa-pen-to-square me-2"></i> Cập Nhật Phiếu Nhập</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-4 shadow-sm py-2 mb-4" role="alert" style="display:none;"></div>
                        
                        <input type="hidden" asp-for="MaPhieuNhap" />
                        <input type="hidden" asp-for="NgayNhap" />
                        <input type="hidden" asp-for="MaNguoiDung" />
                        <input type="hidden" asp-for="MaNhaCungCap" />
                        <input type="hidden" asp-for="TongTien" />
                        <input type="hidden" asp-for="IsDeleted" />

                        <div class="row g-3">
                            <div class="col-md-6 mb-1">
                                <label class="form-label fw-bold text-secondary small text-uppercase ms-1">Mã Phiếu Nhập</label>
                                <input class="form-control form-control-lg rounded-pill fs-6 bg-light border-0 font-monospace text-dark shadow-xs" 
                                       value="#PN-@Model.MaPhieuNhap.ToString("D5")" readonly />
                            </div>

                            <div class="col-md-6 mb-1">
                                <label class="form-label fw-bold text-secondary small text-uppercase ms-1">Thời Gian Nhập</label>
                                <input class="form-control form-control-lg rounded-pill fs-6 bg-light border-0 text-dark shadow-xs" 
                                       value="@Model.NgayNhap.ToString("dd/MM/yyyy HH:mm")" readonly />
                            </div>

                            <div class="col-md-6 mb-1">
                                <label class="form-label fw-bold text-secondary small text-uppercase ms-1">Người Lập Phiếu</label>
                                <input class="form-control form-control-lg rounded-pill fs-6 bg-light border-0 text-dark shadow-xs" 
                                       value="@(Model.MaNguoiDungNavigation?.HoTen ?? "N/A")" readonly />
                            </div>

                            <div class="col-md-6 mb-1">
                                <label class="form-label fw-bold text-secondary small text-uppercase ms-1">Nhà Cung Cấp</label>
                                <input class="form-control form-control-lg rounded-pill fs-6 bg-light border-0 text-dark shadow-xs" 
                                       value="@(Model.MaNhaCungCapNavigation?.TenNhaCungCap ?? "N/A")" readonly />
                            </div>

                            <div class="col-md-12 mb-1">
                                <label class="form-label fw-bold text-secondary small text-uppercase ms-1">Tổng Giá Trị Phiếu (VNĐ)</label>
                                <div class="input-group">
                                    <input class="form-control form-control-lg rounded-pill-start fs-5 bg-light border-0 fw-bold text-primary shadow-xs ps-4" 
                                           value="@Model.TongTien.ToString("N0")" readonly />
                                    <span class="input-group-text bg-light border-0 rounded-pill-end fw-bold text-danger pe-4">VNĐ</span>
                                </div>
                            </div>

                            <div class="col-12 mt-3">
                                <div class="card bg-light border-0 rounded-4 shadow-inner">
                                    <div class="card-body p-3">
                                        <label asp-for="GhiChu" class="form-label fw-bold text-dark mb-1 d-flex align-items-center">
                                            <i class="fa-solid fa-comment-dots me-2 text-warning fs-5"></i> Ghi chú chỉnh sửa
                                        </label>
                                        <textarea asp-for="GhiChu" class="form-control rounded-4 border-0 transition p-2 shadow-inner bg-white" rows="3"
                                                  placeholder="Nhập lý do hoặc thông tin bổ sung khi chỉnh sửa phiếu..."></textarea>
                                        <span asp-validation-for="GhiChu" class="text-danger small"></span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between mt-4 pt-3 border-top">
                            <a asp-action="Index" class="btn btn-light border rounded-pill px-4 fw-medium transition text-secondary">
                                <i class="fa-solid fa-arrow-left me-1"></i> Quay lại
                            </a>
                            <button type="submit" class="btn btn-warning shadow rounded-pill px-5 fw-bold transition">
                                <i class="fa-solid fa-save me-1"></i> Cập nhật
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .rounded-pill-start { border-top-left-radius: 50rem !important; border-bottom-left-radius: 50rem !important; }
    .rounded-pill-end { border-top-right-radius: 50rem !important; border-bottom-right-radius: 50rem !important; }
</style>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
