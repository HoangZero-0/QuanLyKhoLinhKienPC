@model QuanLyKhoLinhKienPC.Models.PhieuNhap

@{
    ViewData["Title"] = "Chi Tiết Phiếu Nhập";
}

<div class="container-fluid pt-4 pb-5 px-sm-4 bg-light">
    <!-- HEADER HÀNH ĐỘNG (Không hiển thị khi in) -->
    <div class="d-flex justify-content-between align-items-center mb-4 no-print mx-auto" style="max-width: 900px;">
        <h2 class="text-info m-0"><i class="fa-solid fa-eye me-1"></i> Chi Tiết Phiếu Nhập</h2>
        <div class="d-flex gap-2">
            @if (User.IsInRole("Quản trị viên") || User.IsInRole("Admin"))
            {
                <a asp-action="Edit" asp-route-id="@Model.MaPhieuNhap" class="btn btn-warning shadow-sm rounded-pill px-4 fw-bold transition">
                    <i class="fa-solid fa-pen-to-square me-1"></i> Chỉnh sửa
                </a>
            }
            @if (User.IsInRole("Quản trị viên") || User.IsInRole("Admin") || User.IsInRole("Nhân viên kho"))
            {
                <button onclick="window.print()" class="btn btn-dark shadow-sm rounded-pill px-4 fw-bold transition">
                    <i class="fa-solid fa-print me-1"></i> In phiếu
                </button>
            }
            <a asp-action="Index" class="btn btn-light border shadow-sm rounded-pill px-4 fw-semibold text-secondary transition">
                <i class="fa-solid fa-arrow-left me-1"></i> Quay lại
            </a>
        </div>
    </div>

    <!-- KHUNG HÓA ĐƠN A4 -->
    <div class="invoice-container bg-white mx-auto p-4 p-md-5" style="max-width: 900px;">
        <!-- Phần Header Cửa hàng -->
        <div class="row border-bottom border-2 border-dark pb-3 mb-4 align-items-center">
            <div class="col-sm-6 text-center text-sm-start mb-3 mb-sm-0">
                <h5 class="fw-bold mb-1 text-uppercase">Cửa Hàng Linh Kiện PC</h5>
                <p class="mb-0 small">Địa chỉ: Long Xuyên, An Giang</p>
                <p class="mb-0 small">Điện thoại: 0123 456 789</p>
            </div>
            <div class="col-sm-6 text-center text-sm-end">
                <h5 class="fw-bold mb-1 text-uppercase">Phiếu Nhập Kho</h5>
                <p class="mb-0 small">Mã số: <strong>#PN-@Model.MaPhieuNhap.ToString("D5")</strong></p>
                <p class="mb-0 small">Ngày lập: @Model.NgayNhap.ToString("dd/MM/yyyy HH:mm")</p>
            </div>
        </div>

        <!-- Thông tin Đối tác / Giao dịch -->
        <div class="row mb-4">
            <div class="col-12">
                <table class="table table-sm table-borderless mb-0">
                    <tbody>
                        <tr>
                            <td class="fw-semibold" style="width: 150px;">Nhà cung cấp:</td>
                            <td class="text-uppercase fw-bold">@Model.MaNhaCungCapNavigation?.TenNhaCungCap</td>
                        </tr>
                        <tr>
                            <td class="fw-semibold">Địa chỉ:</td>
                            <td>@(string.IsNullOrEmpty(Model.MaNhaCungCapNavigation?.DiaChi) ? "---" : Model.MaNhaCungCapNavigation.DiaChi)</td>
                        </tr>
                        <tr>
                            <td class="fw-semibold">Số điện thoại:</td>
                            <td>@(string.IsNullOrEmpty(Model.MaNhaCungCapNavigation?.SoDienThoai) ? "---" : Model.MaNhaCungCapNavigation.SoDienThoai)</td>
                        </tr>
                        <tr>
                            <td class="fw-semibold">Người lập phiếu:</td>
                            <td>@(Model.MaNguoiDungNavigation?.HoTen ?? "Hệ thống")</td>
                        </tr>
                        @if (!string.IsNullOrEmpty(Model.GhiChu))
                        {
                            <tr>
                                <td class="fw-semibold align-top">Ghi chú:</td>
                                <td class="fst-italic">@Model.GhiChu</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Bảng Chi tiết Linh Kiện -->
        <div class="table-responsive mb-3">
            <table class="table table-bordered border-dark align-middle mb-0">
                <thead class="text-center fw-bold" style="background-color: #f8f9fa !important; -webkit-print-color-adjust: exact; print-color-adjust: exact;">
                    <tr>
                        <th style="width: 5%;">STT</th>
                        <th style="width: 40%;">Tên Linh Kiện</th>
                        <th style="width: 10%;">ĐVT</th>
                        <th style="width: 10%;">SL</th>
                        <th style="width: 15%;">Đơn Giá (VNĐ)</th>
                        <th style="width: 20%;">Thành Tiền (VNĐ)</th>
                    </tr>
                </thead>
                <tbody>
                    @{ int stt = 1; }
                    @foreach (var ct in Model.ChiTietPhieuNhap)
                    {
                        <tr>
                            <td class="text-center">@(stt++)</td>
                            <td class="fw-semibold">@ct.MaSanPhamNavigation?.TenSanPham</td>
                            <td class="text-center">Cái</td>
                            <td class="text-center fw-bold">@ct.SoLuong</td>
                            <td class="text-end">@ct.DonGiaNhap.ToString("N0")</td>
                            <td class="text-end fw-bold">@((ct.SoLuong * ct.DonGiaNhap).ToString("N0"))</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="5" class="text-end fw-bold py-3 text-uppercase">Tổng Cộng Tiền Hàng:</td>
                        <td class="text-end fw-bold fs-5 py-3">@Model.TongTien.ToString("N0")</td>
                    </tr>
                </tfoot>
            </table>
            <!-- Viết bằng chữ (Nếu cần, tính sau. Thêm 1 dòng nhỏ phía dưới là được) -->
        </div>

        <!-- Khu vực Seri đính kèm (nếu có) -->
        @if (Model.SeriSanPham != null && Model.SeriSanPham.Any())
        {
            <div class="mb-4 mt-4">
                <div class="border border-dark p-3">
                    <p class="fw-bold mb-2 text-decoration-underline">Bảng kê Mã Seri (SN) chi tiết:</p>
                    <div class="font-monospace lh-lg" style="font-size: 0.85em;">
                        @{
                            var grouped = Model.SeriSanPham.GroupBy(s => s.MaSanPhamNavigation?.TenSanPham);
                            foreach (var group in grouped)
                            {
                                <div class="mb-1">
                                    <span class="fw-bold me-2">@group.Key:</span>
                                    <span>@string.Join(", ", group.Select(s => s.SoSeri))</span>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        }

        <!-- Khu vực Chữ ký -->
        <div class="row pt-4 text-center mt-3" style="page-break-inside: avoid;">
            <div class="col-4">
                <p class="fw-bold mb-0">Người Lập Phiếu</p>
                <p class="text-muted small fst-italic mb-5 pb-4">(Ký, ghi rõ họ tên)</p>
            </div>
            <div class="col-4">
                <p class="fw-bold mb-0">Thủ Kho</p>
                <p class="text-muted small fst-italic mb-5 pb-4">(Ký, ghi rõ họ tên)</p>
            </div>
            <div class="col-4">
                <p class="fw-bold mb-0">Đại Diện Giao Hàng</p>
                <p class="text-muted small fst-italic mb-5 pb-4">(Ký, ghi rõ họ tên)</p>
            </div>
        </div>
    </div>
</div>

<link rel="stylesheet" href="~/css/print-invoice.css" />

<style>
    /* CSS cho vùng hiển thị web */
    .transition { transition: all 0.2s ease; }
    .invoice-container {
        box-shadow: 0 0 20px rgba(0, 0, 0, 0.08);
        border: 1px solid #ced4da;
    }
</style>
