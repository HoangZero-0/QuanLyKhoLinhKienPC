@model QuanLyKhoLinhKienPC.Models.PhieuNhap

@{
    ViewData["Title"] = "Hủy Phiếu Nhập";
}

<div class="container-fluid pt-4 pb-5">
    <div class="row justify-content-center g-4">
        <div class="col-md-7 col-lg-6">
            <div class="card shadow rounded-4 border-0" style="box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.05) !important;">
                <div class="card-header bg-white border-bottom border-light py-3">
                    <h4 class="mb-0 text-danger fw-bold"><i class="fa-solid fa-triangle-exclamation me-1"></i> Hủy Phiếu Nhập</h4>
                </div>
                <div class="card-body text-center p-4">
                    <h5 class="card-title text-danger mb-4">Bạn có chắc muốn chuyển phiếu nhập này vào thùng rác?</h5>

                    <p class="text-muted small mb-4">
                        <i class="fa-solid fa-circle-info"></i> Lưu ý: Hành động này sẽ vô hiệu hóa các mã Seri tương ứng trong kho. Có thể khôi phục lại khi cần.
                    </p>

                    <div class="bg-danger bg-opacity-10 py-4 rounded-4 mx-2 text-start shadow-inner border border-danger border-opacity-10">
                        <div class="row px-4 align-items-center g-3">
                             <div class="col-sm-4 text-end text-danger fw-semibold">Mã phiếu:</div>
                            <div class="col-sm-8 fw-bold text-dark fs-5">#PN-@Model.MaPhieuNhap.ToString("D5")</div>
                            
                            <div class="col-sm-4 text-end text-danger fw-semibold">Ngày nhập:</div>
                            <div class="col-sm-8 fw-bold text-primary">@Model.NgayNhap.ToString("dd/MM/yyyy HH:mm")</div>

                            <div class="col-sm-4 text-end text-danger fw-semibold">Nhà cung cấp:</div>
                            <div class="col-sm-8 fw-bold text-secondary">@Model.MaNhaCungCapNavigation?.TenNhaCungCap</div>
                            
                            <div class="col-sm-4 text-end text-danger fw-semibold">Tổng giá trị:</div>
                            <div class="col-sm-8 text-danger fw-bold fs-4">@string.Format("{0:N0}", Model.TongTien) VNĐ</div>
                            
                            <div class="col-sm-4 text-end text-danger fw-semibold">Ghi chú:</div>
                            <div class="col-sm-8 text-muted small">@(string.IsNullOrEmpty(Model.GhiChu) ? "(Không có)" : Model.GhiChu)</div>
                        </div>
                    </div>

                    <form asp-action="Delete" class="mt-5">
                        <input type="hidden" asp-for="MaPhieuNhap" />
                        <a asp-action="Index" class="btn btn-light border shadow-sm rounded-pill px-4 text-secondary fw-semibold me-3 transition">
                            <i class="fa-solid fa-xmark me-1"></i> Hủy bỏ
                        </a>
                        <button type="submit" class="btn btn-danger shadow rounded-pill px-5 fw-bold transition">
                            <i class="fa-solid fa-trash me-1"></i> Đồng ý xóa
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .transition { transition: all 0.2s ease; }
    .shadow-inner { box-shadow: inset 0 2px 4px 0 rgba(0, 0, 0, 0.05); }
</style>
