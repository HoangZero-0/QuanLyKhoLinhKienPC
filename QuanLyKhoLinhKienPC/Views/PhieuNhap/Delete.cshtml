@model QuanLyKhoLinhKienPC.Models.PhieuNhap

@{
    ViewData["Title"] = "Xóa Phiếu Nhập";
}

<style>
    .transition { transition: all 0.2s ease; }
    .shadow-inner { box-shadow: inset 0 2px 4px 0 rgba(0, 0, 0, 0.05); }
    .font-monospace { font-family: 'JetBrains Mono', 'Roboto Mono', monospace; }
</style>

<div class="container-fluid pt-4">
    <div class="row justify-content-center g-4">
        <div class="col-md-6">
            <div class="card shadow rounded-4 border-0" style="box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.05) !important;">
                <div class="card-header bg-white border-bottom border-light py-3">
                    <h4 class="mb-0 text-danger fw-bold"><i class="fa-solid fa-triangle-exclamation me-1"></i> Xóa Phiếu Nhập</h4>
                </div>
                <div class="card-body text-center p-4">
                    <h5 class="card-title text-danger mb-4">Bạn có chắc muốn chuyển Phiếu nhập này vào thùng rác?</h5>

                    <p class="text-muted small mb-4">
                        <i class="fa-solid fa-circle-info"></i> Lưu ý: Dữ liệu sẽ được chuyển vào Thùng rác (có thể khôi phục lại khi cần).
                    </p>

                    <div class="bg-danger bg-opacity-10 py-4 rounded-4 mx-2 text-start shadow-inner border border-danger border-opacity-10">
                        <div class="row px-4 align-items-center g-3 pb-2">
                            <div class="col-sm-4 text-danger fw-semibold">Mã Phiếu:</div>
                            <div class="col-sm-8 fw-bold text-dark fs-5">#PN-@Model.MaPhieuNhap.ToString("D5")</div>
                            
                            <div class="col-sm-4 text-danger fw-semibold">Thời Gian:</div>
                            <div class="col-sm-8 text-dark">@Model.NgayNhap.ToString("dd/MM/yyyy HH:mm")</div>

                            <div class="col-sm-4 text-danger fw-semibold">Người Nhập:</div>
                            <div class="col-sm-8 text-dark">@(Model.MaNguoiDungNavigation?.HoTen ?? "N/A")</div>

                            <div class="col-sm-4 text-danger fw-semibold">Nhà Cung Cấp:</div>
                            <div class="col-sm-8 text-dark">@(Model.MaNhaCungCapNavigation?.TenNhaCungCap ?? "N/A")</div>

                            <div class="col-sm-4 text-danger fw-semibold">Ghi Chú:</div>
                            <div class="col-sm-8 text-dark fst-italic">@(string.IsNullOrEmpty(Model.GhiChu) ? "Không có" : Model.GhiChu)</div>
                            
                            <div class="col-sm-4 text-danger fw-semibold">Tổng Tiền:</div>
                            <div class="col-sm-8 text-dark">@Model.TongTien.ToString("N0") VNĐ</div>
                        </div>
                    </div>

                    <form asp-action="Delete" class="mt-5 d-flex justify-content-between px-2">
                        <input type="hidden" asp-for="MaPhieuNhap" />
                        <a asp-action="Index" class="btn btn-light border shadow-sm rounded-pill px-4 text-secondary fw-semibold transition">
                            <i class="fa-solid fa-xmark me-1"></i> Hủy bỏ
                        </a>
                        <button type="submit" class="btn btn-danger shadow rounded-pill px-5 fw-bold transition">
                            <i class="fa-solid fa-trash me-1"></i> Đồng ý xóa
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
