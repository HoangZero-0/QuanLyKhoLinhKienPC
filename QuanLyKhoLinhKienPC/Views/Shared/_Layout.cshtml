<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Quản Lý Kho Linh Kiện PC</title>
    <link rel="icon" type="image/x-icon" href="~/favicon.ico?v=1.0" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        /* 1. KHÓA CUỘN TOÀN TRANG */
        html, body {
            height: 100%;
            margin: 0;
            overflow: hidden;
            background-color: #f8fafc; /* Xám băng siêu nhạt */
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
        }
        /* Gắn background họa tiết orbs ảo (Glassmorphism) */
        body::before {
            content: '';
            position: absolute;
            top: -100px;
            left: -100px;
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, rgba(56, 189, 248, 0.2) 0%, rgba(255, 255, 255, 0) 70%);
            border-radius: 50%;
            z-index: -1;
        }
        body::after {
            content: '';
            position: absolute;
            bottom: -150px;
            right: -50px;
            width: 500px;
            height: 500px;
            background: radial-gradient(circle, rgba(167, 139, 250, 0.15) 0%, rgba(255, 255, 255, 0) 70%);
            border-radius: 50%;
            z-index: -1;
        }

        /* Cấu trúc Flex dọc */
        body {
            display: flex;
            flex-direction: column;
            zoom: 0.8; /* Thu nhỏ giao diện xuống 80% */
            height: 125vh; /* Đảm bảo đủ chiều cao khi bị thu nhỏ 20% (100 / 0.8 = 125) */
        }

        /* Navbar và Footer cố định */
        .navbar, .footer {
            flex-shrink: 0;
            z-index: 1001;
        }

        /* 2. WRAPPER CHÍNH */
        .wrapper {
            flex: 1;
            display: flex;
            overflow: hidden; /* Ngăn tràn màn hình */
        }

        /* 3. SIDEBAR GLASSMORPHISM */
        .sidebar {
            width: 260px;
            background: rgba(255, 255, 255, 0.6);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border-right: 1px solid rgba(255, 255, 255, 0.8);
            color: #334155;
            display: flex;
            flex-direction: column;
            overflow-y: auto;
            overflow-x: hidden;
            flex-shrink: 0;
            transition: all 0.3s;
            box-shadow: 4px 0 15px rgba(0,0,0,0.02);
        }

            .sidebar .nav-link {
                color: #64748b;
                padding: 12px 20px;
                font-size: 15px;
                font-weight: 500;
                transition: all 0.25s ease-in-out;
                border-radius: 12px;
                margin: 4px 12px;
                display: flex;
                align-items: center;
            }

                .sidebar .nav-link i {
                    margin-right: 12px;
                    width: 25px;
                    text-align: center;
                    font-size: 18px;
                    color: #94a3b8;
                    transition: color 0.25s ease-in-out;
                }

                /* Hiệu ứng Hover */
                .sidebar .nav-link:hover {
                    background: rgba(241, 245, 249, 0.8);
                    color: #0f172a;
                    transform: translateX(4px);
                }
                .sidebar .nav-link:hover i {
                    color: #3b82f6;
                }

                /* Active State */
                .sidebar .nav-link.active {
                    background: linear-gradient(135deg, #0ea5e9 0%, #3b82f6 100%);
                    color: #ffffff;
                    font-weight: 600;
                    box-shadow: 0 4px 12px rgba(59, 130, 246, 0.3);
                }
                .sidebar .nav-link.active i {
                    color: #ffffff;
                }

        /* 4. CONTENT AREA */
        .content {
            flex: 1;
            padding: 24px 32px;
            background: transparent;
            overflow-y: auto; /* Cho phép cuộn phần nội dung bên phải */
            display: flex;
            flex-direction: column;
        }

        .footer {
            background: #fff;
            padding: 10px;
            border-top: 1px solid #dee2e6;
            text-align: center;
            font-size: 0.85rem;
            color: #6c757d;
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    @{
        string? currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
    }

    <nav class="navbar navbar-expand bg-white border-bottom px-4 shadow-sm" style="background: rgba(255,255,255,0.85) !important; backdrop-filter: blur(12px);">
        <a class="navbar-brand fw-bold text-dark" href="/">
            <div class="d-flex align-items-center">
                <img src="~/images/logo.png" alt="Logo" style="width: 45px; height: 45px; object-fit: contain;" class="me-2 rounded shadow-sm" />
                <span style="letter-spacing: -0.5px; font-size: 1.25rem; font-weight: 800;">KHO LINH KIỆN PC</span>
            </div>
        </a>
        <div class="d-flex align-items-center ms-auto">
            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <span class="text-secondary me-4 fw-medium">
                    Xin chào, 
                    <a asp-controller="HoSo" asp-action="Index" class="text-primary text-decoration-none fw-bold mx-1" title="Xem hồ sơ cá nhân">
                        @User.FindFirst("HoTen")?.Value
                    </a>
                    <span class="badge bg-light text-primary border border-primary-subtle rounded-pill ms-1 px-3">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</span>
                </span>
                <form asp-controller="Auth" asp-action="Logout" method="post" class="d-inline">
                    <button type="submit" class="btn btn-sm btn-light border shadow-sm text-danger fw-medium rounded-pill px-3 hover-shadow-sm transition"><i class="fa-solid fa-right-from-bracket me-1"></i> Đăng xuất</button>
                </form>
            }
            else
            {
                <a asp-controller="Auth" asp-action="Login" class="btn btn-sm btn-primary rounded-pill px-4 shadow-sm fw-medium"><i class="fa-solid fa-right-to-bracket me-1"></i> Đăng nhập</a>
            }
        </div>
    </nav>

    <div class="wrapper">
        <nav class="sidebar shadow">
            <ul class="nav flex-column pt-3">
                <li class="nav-item">
                    <a class="nav-link @(currentController == "Home" ? "active" : "")" asp-controller="Home" asp-action="Index">
                        <i class="fa-solid fa-house"></i> Trang chủ
                    </a>
                </li>

                <li class="nav-item mt-2">
                    <div class="text-muted small fw-bold px-3 text-uppercase">Quản lý kho</div>
                </li>

                <li class="nav-item">
                    <a class="nav-link @(currentController == "NhaCungCap" ? "active" : "")" asp-controller="NhaCungCap" asp-action="Index">
                        <i class="fa-solid fa-truck-field"></i> Nhà cung cấp
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(currentController == "DanhMuc" ? "active" : "")" asp-controller="DanhMuc" asp-action="Index">
                        <i class="fa-solid fa-list"></i> Danh mục
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(currentController == "SanPham" ? "active" : "")" asp-controller="SanPham" asp-action="Index">
                        <i class="fa-solid fa-box-open"></i> Sản phẩm
                    </a>
                </li>

                <li class="nav-item mt-2">
                    <hr class="text-secondary mx-3 my-2">
                    <div class="px-3 text-uppercase text-muted" style="font-size: 11px; font-weight: bold; margin-bottom: 5px;">Nghiệp vụ</div>
                </li>

                <li class="nav-item">
                    <a class="nav-link @(currentController == "PhieuNhap" ? "active" : "")" asp-controller="PhieuNhap" asp-action="Index">
                        <i class="fa-solid fa-file-import"></i> Nhập kho
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(currentController == "PhieuXuat" ? "active" : "")" asp-controller="PhieuXuat" asp-action="Index">
                        <i class="fa-solid fa-file-invoice-dollar"></i> Xuất kho / Bán hàng
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(currentController == "SeriSanPham" ? "active" : "")" asp-controller="SeriSanPham" asp-action="Index">
                        <i class="fa-solid fa-barcode"></i> Kho Seri
                    </a>
                </li>

                @if (User.IsInRole("Quản trị viên") || User.IsInRole("Admin"))
                {
                    <li class="nav-item mt-2">
                        <hr class="text-secondary mx-3 my-2">
                        <div class="px-3 text-uppercase text-muted" style="font-size: 11px; font-weight: bold; margin-bottom: 5px;">Hệ thống</div>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link @(currentController == "VaiTro" ? "active" : "")" asp-controller="VaiTro" asp-action="Index">
                            <i class="fa-solid fa-user-shield"></i> Vai trò
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "NguoiDung" ? "active" : "")" asp-controller="NguoiDung" asp-action="Index">
                            <i class="fa-solid fa-users"></i> Nhân viên
                        </a>
                    </li>
                }
            </ul>
        </nav>

        <main class="content">
            <!-- Render thông báo TempData (Global) -->
            <div class="flex-shrink-0">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
                        <i class="fa-solid fa-check-circle"></i> @TempData["Success"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
                        <i class="fa-solid fa-circle-xmark"></i> @TempData["Error"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
                @if (TempData["Warning"] != null)
                {
                    <div class="alert alert-warning alert-dismissible fade show shadow-sm" role="alert">
                        <i class="fa-solid fa-triangle-exclamation"></i> @TempData["Warning"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
            </div>

            @RenderBody()
        </main>
    </div>

    <footer class="footer">
        &copy; 2026 - Hệ thống Quản lý kho linh kiện PC - HoangZero
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    
    <script>
        $(document).ready(function () {
            // 1. Định nghĩa hàm Toast toàn cục để dùng ở mọi nơi
            window.showToast = function(message, type = 'info') {
                const Toast = Swal.mixin({
                    toast: true,
                    position: 'top',
                    showConfirmButton: false,
                    timer: 3000,
                    timerProgressBar: true,
                    didOpen: (toast) => {
                        toast.onmouseenter = Swal.stopTimer;
                        toast.onmouseleave = Swal.resumeTimer;
                    }
                });

                Toast.fire({
                    icon: type,
                    title: message
                });
            };

            // 2. Hàm xác nhận hành động chuyên nghiệp
            window.confirmAction = function(title, text, icon = 'question', callback) {
                Swal.fire({
                    title: title,
                    text: text,
                    icon: icon,
                    showCancelButton: true,
                    confirmButtonColor: '#3085d6',
                    cancelButtonColor: '#d33',
                    confirmButtonText: 'Xác nhận',
                    cancelButtonText: 'Hủy',
                    heightAuto: false // Ngăn cuộn trang lên đầu khi hiện modal
                }).then((result) => {
                    if (result.isConfirmed && typeof callback === 'function') {
                        callback();
                    }
                });
            };

            // 3. Chuyển đối các Alert tĩnh thành SweetAlert Toast hiện đại
            $('.alert').each(function () {
                var $alert = $(this);
                
                // Trích xuất nội dung thực tế (bỏ đi các ký hiệu icon, close x, và title dư thừa)
                var rawText = $alert.text();
                // Regex loại bỏ 'Thất bại:', 'Thành công:', 'Lưu ý:' và khoảng trắng
                var message = rawText.replace(/Thất bại:|Thành công:|Lưu ý:/gi, '').replace('×', '').trim();
                
                var iconType = 'info';
                if ($alert.hasClass('alert-success')) iconType = 'success';
                else if ($alert.hasClass('alert-danger')) iconType = 'error';
                else if ($alert.hasClass('alert-warning')) iconType = 'warning';

                // Ẩn bảng HTML Alert cứng đi (Chỉ dùng dữ liệu tạo Toast)
                $alert.hide();

                // Kích hoạt Toast sau 100ms
                setTimeout(function() {
                    showToast(message, iconType);
                }, 100);
            });

            // Global SweetAlert Confirm Form Submit (Bắt lỗi Localhost Says gốc)
            $('form[data-confirm]').on('submit', function (e) {
                e.preventDefault();
                var form = this;
                var message = $(form).attr('data-confirm');
                Swal.fire({
                    title: 'Xác nhận hành động nguy hiểm',
                    html: message.replace(/\\n/g, '<br/>'),
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#d33',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: '<i class="fa-solid fa-check"></i> Đồng ý',
                    cancelButtonText: 'Hủy bỏ',
                    heightAuto: false,
                    scrollbarPadding: false
                }).then((result) => {
                    if (result.isConfirmed) {
                        // Bỏ data confirm đi để submit thật sự
                        form.removeAttribute('data-confirm');
                        form.submit();
                    }
                });
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>