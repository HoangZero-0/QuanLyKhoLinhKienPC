@model ErrorViewModel
@{
    ViewData["Title"] = ViewData["ErrorTitle"] ?? "Lỗi Hệ Thống";
}

<div class="container d-flex align-items-center justify-content-center min-vh-100 py-5">
    <div class="text-center">
        <!-- ICON DYNAMIC -->
        <div class="mb-4">
            @if (ViewData["ErrorTitle"]?.ToString() == "Không Tìm Thấy Trang")
            {
                <div class="display-1 fw-bold text-muted opacity-25 mb-0" style="font-size: 8rem;">404</div>
                <div class="mt-n5">
                    <i class="fa-solid fa-map-location-dot text-primary" style="font-size: 5rem;"></i>
                </div>
            }
            else if (ViewData["ErrorTitle"]?.ToString() == "Truy Cập Bị Từ Chối")
            {
                <i class="fa-solid fa-shield-halved text-danger" style="font-size: 6rem;"></i>
            }
            else
            {
                <i class="fa-solid fa-gears text-warning" style="font-size: 6rem;"></i>
            }
        </div>

        <h1 class="fw-bold text-dark mb-3">@ViewData["ErrorTitle"]</h1>
        <p class="text-muted fs-5 mb-5 mx-auto" style="max-width: 500px;">
            @ViewData["ErrorMessage"]
        </p>

        <div class="d-flex justify-content-center gap-3">
            <a href="/" class="btn btn-primary btn-lg rounded-pill px-5 shadow-sm transition">
                <i class="fa-solid fa-house me-2"></i> Quay lại trang chủ
            </a>
            <button onclick="window.location.reload()" class="btn btn-light border btn-lg rounded-pill px-4 shadow-sm transition">
                <i class="fa-solid fa-rotate me-2"></i> Thử lại
            </button>
        </div>

        @if (Model.ShowRequestId)
        {
            <div class="mt-5 pt-4 border-top">
                <p class="text-secondary small mb-0">
                    <i class="fa-solid fa-circle-info me-1"></i> 
                    Mã yêu cầu hỗ trợ (Request ID): <code class="bg-light px-2 py-1 rounded text-primary">@Model.RequestId</code>
                </p>
                <p class="text-muted small mt-2">Vui lòng cung cấp mã này nếu bạn cần hỗ trợ kỹ thuật.</p>
            </div>
        }
    </div>
</div>

<style>
    .transition {
        transition: all 0.3s ease;
    }
    .transition:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
    }
    .mt-n5 {
        margin-top: -4rem;
    }
</style>
