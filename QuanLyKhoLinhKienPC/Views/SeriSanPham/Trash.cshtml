@model IEnumerable<QuanLyKhoLinhKienPC.Models.SeriSanPham>

@{
    ViewData["Title"] = "Thùng Rác Kho Seri";
}

<div class="d-flex flex-column h-100">
    <div class="d-flex justify-content-between align-items-center mb-3 flex-shrink-0">
        <h2 class="text-danger m-0"><i class="fa-solid fa-trash-can"></i> Thùng Rác Kho Seri</h2>
        <div>
            <a asp-action="Index" class="btn btn-light border shadow-sm rounded-pill px-4 fw-medium transition">
                <i class="fa-solid fa-arrow-left me-1"></i> Quay lại
            </a>
        </div>
    </div>

    <div class="flex-shrink-0">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show shadow-sm rounded-4" role="alert">
                <i class="fa-solid fa-check-circle"></i> @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show shadow-sm rounded-4" role="alert">
                <i class="fa-solid fa-circle-exclamation"></i> @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
    </div>

    <!-- FILTER BAR -->
    <div class="card mb-4 shadow rounded-4 flex-shrink-0 border-0" style="box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.05) !important;">
        <div class="card-body py-3 px-4">
            <form asp-action="Trash" method="get" class="row g-3 align-items-center">
                <div class="col-md-10">
                    <div class="input-group input-group-lg">
                        <span class="input-group-text bg-white text-muted border-end-0 rounded-start-pill ps-4"><i class="fa-solid fa-magnifying-glass"></i></span>
                        <input type="text" name="SearchString" class="form-control border-start-0 rounded-end-pill fs-6 ps-0" placeholder="Tìm tên sản phẩm, mã Seri trong thùng rác..." value="@ViewData["CurrentFilter"]">
                    </div>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-dark btn-lg w-100 fw-bold rounded-pill fs-6 shadow-sm">Tìm kiếm</button>
                </div>
            </form>
        </div>
    </div>

    <!-- DATA TABLE -->
    <div class="card shadow rounded-4 flex-grow-1 overflow-hidden border-0" style="box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.05) !important;">
        <div class="card-body p-0 position-relative">
            <div class="table-responsive" style="position: absolute; top: 0; bottom: 0; left: 0; right: 0; overflow-x: hidden;">
                <style>
                    .premium-table tbody tr {
                        transition: all 0.2s;
                        border-bottom: 1px solid #f1f5f9;
                    }
                    .premium-table tbody tr:hover {
                        background-color: #fca5a510 !important;
                        transform: scale(1.002);
                    }
                    .premium-table th {
                        border-bottom: 2px solid #fecaca !important;
                        color: #ef4444;
                        font-weight: 600;
                        text-transform: uppercase;
                        font-size: 0.85rem;
                        letter-spacing: 0.5px;
                    }
                </style>
                <table class="table premium-table mb-0 w-100 align-middle">
                    <thead class="bg-white">
                        <tr>
                            <th class="py-4 ps-4 text-center" style="width: 5%; position: sticky; top: 0; z-index: 10; background: rgba(255,255,255,0.95); backdrop-filter: blur(8px);">STT</th>
                            <th class="py-4" style="position: sticky; top: 0; z-index: 10; background: rgba(255,255,255,0.95); backdrop-filter: blur(8px);">Mã Số Seri</th>
                            <th class="py-4" style="position: sticky; top: 0; z-index: 10; background: rgba(255,255,255,0.95); backdrop-filter: blur(8px);">Sản Phẩm</th>
                            <th class="py-4" style="position: sticky; top: 0; z-index: 10; background: rgba(255,255,255,0.95); backdrop-filter: blur(8px);">Phiếu Nhập</th>
                            <th class="py-4" style="position: sticky; top: 0; z-index: 10; background: rgba(255,255,255,0.95); backdrop-filter: blur(8px);">Giá Nhập</th>
                            <th class="py-4 text-center pe-4" style="width: 150px; position: sticky; top: 0; z-index: 10; background: rgba(255,255,255,0.95); backdrop-filter: blur(8px);">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-5">
                                    <div class="py-4">
                                        <i class="fa-regular fa-trash-can fa-3x mb-3 text-secondary opacity-25"></i>
                                        <p class="fs-5 fw-medium mb-1">Thùng rác trống</p>
                                    </div>
                                </td>
                            </tr>
                        }
                        else
                        {
                            int stt = 1;
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="text-center text-secondary fw-medium align-middle ps-4">@(stt++)</td>
                                    <td class="fw-bold text-dark py-4 align-middle">
                                        <span class="px-2 py-1 bg-light rounded text-monospace">@item.SoSeri</span>
                                    </td>
                                    <td class="fw-bold">
                                        <div class="text-dark">@item.MaSanPhamNavigation?.TenSanPham</div>
                                        <div class="d-flex flex-wrap gap-2 mt-2 align-items-center">
                                            @if (item.MaSanPhamNavigation?.MaDanhMucNavigation != null)
                                            {
                                                <span class="badge rounded-pill bg-light text-secondary border px-2 py-1 fw-medium" style="font-size: 0.75rem;">
                                                    <i class="fa-solid fa-layer-group me-1 opacity-75"></i> 
                                                    @item.MaSanPhamNavigation.MaDanhMucNavigation.TenDanhMuc
                                                </span>
                                            }
                                            <span class="badge rounded-pill bg-light text-secondary border px-2 py-1 fw-medium" style="font-size: 0.75rem;">
                                                <i class="fa-solid fa-industry me-1 opacity-75"></i> 
                                                @(string.IsNullOrEmpty(item.MaSanPhamNavigation?.HangSanXuat) ? "N/A" : item.MaSanPhamNavigation.HangSanXuat)
                                            </span>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="text-secondary fw-bold bg-light px-2 py-1 rounded">
                                            #PN-@item.MaPhieuNhap?.ToString("D5")
                                        </span>
                                    </td>
                                    <td>
                                        @{
                                            var giaNhap = item.MaPhieuNhapNavigation?.ChiTietPhieuNhap?.FirstOrDefault(ct => ct.MaSanPham == item.MaSanPham)?.DonGiaNhap;
                                        }
                                        @if(giaNhap.HasValue)
                                        {
                                            <span class="fw-bold text-danger">@string.Format("{0:N0}", giaNhap) VNĐ</span>
                                        }
                                    </td>
                                    <td class="text-center pe-4">
                                        <form asp-action="Restore" asp-route-id="@item.MaSeri" method="post" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-light border text-success rounded-circle d-inline-flex align-items-center justify-content-center transition shadow-xs" style="width: 35px; height: 35px;" title="Khôi phục">
                                                <i class="fa-solid fa-rotate-left"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
