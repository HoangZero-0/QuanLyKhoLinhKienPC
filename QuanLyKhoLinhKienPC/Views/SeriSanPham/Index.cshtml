@model IEnumerable<QuanLyKhoLinhKienPC.Models.SeriSanPham>

@{
    ViewData["Title"] = "Quản Lý Kho Seri";
}

<style>
    @@media print {
        /* Ẩn các thành phần của Layout */
        .navbar, .sidebar, .footer { 
            display: none !important; 
        }
        
        /* Trải rộng vùng Content */
        .wrapper, .content {
            margin: 0 !important;
            padding: 0 !important;
            width: 100% !important;
            max-width: 100% !important;
            display: block !important;
        }

        /* Xoá format của trang để in trắng tinh */
        body, html {
            background-color: white !important;
            zoom: 1 !important; /* Bỏ zoom 0.8 của layout */
            height: auto !important;
            overflow: visible !important;
            padding-top: 10mm !important; 
            padding-bottom: 10mm !important;
            padding-left: 15mm !important; 
            padding-right: 15mm !important;
        }

        /* Khắc phục bảng biến mất do absolute/fixed height */
        .h-100, .flex-column, .card:not(.d-print-none), .card-body, .table-responsive {
            height: auto !important;
            display: block !important;
            position: static !important;
            min-height: auto !important;
            overflow: visible !important;
        }

        /* Ẩn triệt để thanh cuộn (Scrollbar) Windows bị dính vào khi in */
        ::-webkit-scrollbar {
            display: none !important;
        }
        * {
            -ms-overflow-style: none !important;
            scrollbar-width: none !important;
        }
        
        .table-responsive {
            top: auto !important;
            bottom: auto !important;
            left: auto !important;
            right: auto !important;
        }

        /* Xoá bóng râm và viền của thẻ Card */
        .card {
            border: none !important;
            box-shadow: none !important;
        }

        /* Khắc phục lỗi "Vạch dọc ảo" của Trình duyệt khi in Bootstrap Table */
        .table > tbody > tr > *,
        .table > thead > tr > * {
            box-shadow: none !important;
            border-left: none !important;
            border-right: none !important;
            background-clip: padding-box !important;
        }
        
        .table-striped > tbody > tr:nth-of-type(odd) > * {
            background-color: #f2f2f2 !important; /* Dùng màu thật thay thế bóng đổ nội bộ */
        }

        /* Đẩy nội dung in ra trọn trang giấy, giấu tiêu đề phụ do trình duyệt sinh ra (Ngày tháng, URL) */
        @Html.Raw("@page { margin: 0; }")
    }

    /* Custom hover effect */
    .premium-table tbody tr {
        transition: all 0.2s;
        border-bottom: 1px solid #f1f5f9;
    }
    .premium-table tbody tr:hover {
        background-color: #f8fafc !important;
        transform: scale(1.002);
    }
    .premium-table th {
        border-bottom: 2px solid #e2e8f0 !important;
        color: #64748b;
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.85rem;
        letter-spacing: 0.5px;
    }
</style>

<div class="d-flex flex-column h-100">
    <div class="d-flex justify-content-between align-items-center mb-3 flex-shrink-0 d-print-none">
        <h2 class="text-primary m-0"><i class="fa-solid fa-barcode"></i> Quản Lý Kho Seri</h2>
        @if (User.IsInRole("Quản trị viên") || User.IsInRole("Admin") || User.IsInRole("Nhân viên kho"))
        {
            <div>
                <a asp-action="Trash" class="btn btn-light border shadow-sm rounded-pill px-3 transition text-danger" title="Thùng rác">
                    <i class="fa-solid fa-trash-can"></i>
                </a>
            </div>
        }
    </div>

    <!-- TIÊU ĐỀ IN ẤN (Chỉ hiển thị khi in) -->
    <div class="d-none d-print-block text-center mb-4">
        <h2 class="text-uppercase fw-bold">BÁO CÁO THỐNG KÊ KHO SERI</h2>
        <p class="text-muted">
            Ngày in: @DateTime.Now.ToString("dd/MM/yyyy HH:mm") <br/>
            @if(ViewData["FromDate"] != null || ViewData["ToDate"] != null)
            {
                <span>Thời gian: @(ViewData["FromDate"]?.ToString() ?? "...") đến @(ViewData["ToDate"]?.ToString() ?? "...")</span> <br/>
            }
            Trạng thái: 
            @(ViewData["TrangThaiFilter"]?.ToString() == "1" ? "Tồn Kho" : 
              ViewData["TrangThaiFilter"]?.ToString() == "2" ? "Đã Bán" : 
              ViewData["TrangThaiFilter"]?.ToString() == "3" ? "Lỗi/Bảo Hành" : "Tất cả")
        </p>
    </div>

    <div class="flex-shrink-0 d-print-none">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show shadow-sm rounded-4" role="alert">
                <i class="fa-solid fa-check-circle"></i> @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show shadow-sm rounded-4" role="alert">
                <i class="fa-solid fa-circle-exclamation"></i> @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["Warning"] != null)
        {
            <div class="alert alert-warning alert-dismissible fade show shadow-sm rounded-4" role="alert">
                <i class="fa-solid fa-triangle-exclamation"></i> @TempData["Warning"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
    </div>

    <!-- FILTER BAR -->
    <div class="card mb-4 shadow rounded-4 flex-shrink-0 border-0 d-print-none" style="box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.05) !important;">
        <div class="card-body py-3 px-4">
            <form asp-action="Index" method="get">
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <div class="input-group input-group-lg">
                            <span class="input-group-text bg-white text-muted border-end-0 rounded-start-pill ps-4"><i class="fa-solid fa-magnifying-glass"></i></span>
                            <input type="text" name="SearchString" class="form-control border-start-0 rounded-end-pill fs-6 ps-0" placeholder="Tìm tên sản phẩm, mã Seri..." value="@ViewData["CurrentFilter"]">
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="input-group input-group-lg">
                            <span class="input-group-text bg-white text-muted border-end-0 rounded-start-pill ps-4"><i class="fa-solid fa-filter"></i></span>
                            <select name="TrangThaiFilter" class="form-select border-start-0 rounded-end-pill fs-6 ps-0" onchange="this.form.submit()">
                                <option value="">-- Tất cả trạng thái --</option>
                                <option value="1" selected="@(ViewData["TrangThaiFilter"]?.ToString() == "1")">Tồn Kho (Chưa Bán)</option>
                                <option value="2" selected="@(ViewData["TrangThaiFilter"]?.ToString() == "2")">Đã Bán</option>
                                <option value="3" selected="@(ViewData["TrangThaiFilter"]?.ToString() == "3")">Lỗi/Bảo Hành</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn btn-dark btn-lg w-100 fw-bold rounded-pill fs-6 shadow-sm"><i class="fa-solid fa-magnifying-glass"></i> Tìm kiếm</button>
                    </div>
                </div>
                <div class="row g-3">
                    <div class="col-md-4">
                        <div class="input-group input-group-lg">
                            <span class="input-group-text bg-white text-muted border-end-0 rounded-start-pill ps-4 fs-6">Từ Ngày</span>
                            <input type="date" name="fromDate" id="fromDateInput" class="form-control border-start-0 rounded-end-pill fs-6 ps-0" min="1753-01-01" max="9999-12-31" value="@ViewData["FromDate"]" onchange="validateAndSubmit(this)" onkeydown="return false">
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="input-group input-group-lg">
                            <span class="input-group-text bg-white text-muted border-end-0 rounded-start-pill ps-4 fs-6">Đến Ngày</span>
                            <input type="date" name="toDate" id="toDateInput" class="form-control border-start-0 rounded-end-pill fs-6 ps-0" min="1753-01-01" max="9999-12-31" value="@ViewData["ToDate"]" onchange="validateAndSubmit(this)" onkeydown="return false">
                        </div>
                    </div>
                    <div class="col-md-4">
                        <button type="button" class="btn btn-light border btn-lg w-100 fw-bold rounded-pill fs-6 shadow-sm" onclick="window.print()"><i class="fa-solid fa-print"></i> In Thống Kê</button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- DATA TABLE -->
    <div class="card shadow rounded-4 flex-grow-1 overflow-hidden border-0" style="box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.05) !important;">
        <div class="card-body p-0 position-relative">
            <div class="table-responsive" style="position: absolute; top: 0; bottom: 0; left: 0; right: 0; overflow-x: hidden;">
                <table class="table premium-table mb-0 w-100 align-middle">
                    <thead class="bg-white">
                        <tr>
                            <th class="py-4 ps-4 text-center" style="width: 5%; position: sticky; top: 0; z-index: 10; background: rgba(255,255,255,0.95); backdrop-filter: blur(8px);">STT</th>
                            <th class="py-4" style="position: sticky; top: 0; z-index: 10; background: rgba(255,255,255,0.95); backdrop-filter: blur(8px);">Mã Số Seri</th>
                            <th class="py-4" style="position: sticky; top: 0; z-index: 10; background: rgba(255,255,255,0.95); backdrop-filter: blur(8px);">Sản Phẩm</th>
                            <th class="py-4" style="position: sticky; top: 0; z-index: 10; background: rgba(255,255,255,0.95); backdrop-filter: blur(8px);">Phiếu Nhập</th>
                            <th class="py-4" style="position: sticky; top: 0; z-index: 10; background: rgba(255,255,255,0.95); backdrop-filter: blur(8px);">Giá Nhập</th>
                            <th class="py-4 text-center" style="position: sticky; top: 0; z-index: 10; background: rgba(255,255,255,0.95); backdrop-filter: blur(8px);">Trạng Thái Kho</th>
                            <th class="py-4 text-center d-print-none pe-4" style="width: 150px; position: sticky; top: 0; z-index: 10; background: rgba(255,255,255,0.95); backdrop-filter: blur(8px);">Hành Động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted py-5 font-italic">
                                    <i class="fa-solid fa-barcode fa-3x mb-3 text-secondary opacity-50"></i><br>
                                    Không tìm thấy dữ liệu nào.
                                </td>
                            </tr>
                        }
                        else
                        {
                            int stt = 1;
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="text-center text-secondary fw-medium align-middle ps-4">@(stt++)</td>
                                    <td class="fw-bold text-dark py-4 align-middle">
                                        <span class="px-2 py-1 bg-light rounded text-monospace">@item.SoSeri</span>
                                    </td>
                                    <td class="fw-bold">
                                        <a asp-controller="SanPham" asp-action="Details" asp-route-id="@item.MaSanPham" class="text-decoration-none text-primary hover-underline" title="Xem chi tiết linh kiện này">
                                            @item.MaSanPhamNavigation?.TenSanPham
                                        </a>
                                        <div class="d-flex flex-wrap gap-2 mt-2 align-items-center">
                                            @if (item.MaSanPhamNavigation?.MaDanhMucNavigation != null)
                                            {
                                                <span class="badge rounded-pill bg-primary bg-opacity-10 text-primary px-2 py-1 fw-medium" style="font-size: 0.75rem;">
                                                    <i class="fa-solid fa-layer-group me-1 opacity-75"></i> 
                                                    @item.MaSanPhamNavigation.MaDanhMucNavigation.TenDanhMuc
                                                </span>
                                            }
                                            <span class="badge rounded-pill bg-primary bg-opacity-10 text-primary px-2 py-1 fw-medium" style="font-size: 0.75rem;">
                                                <i class="fa-solid fa-industry me-1 opacity-75"></i> 
                                                @(string.IsNullOrEmpty(item.MaSanPhamNavigation?.HangSanXuat) ? "N/A" : item.MaSanPhamNavigation.HangSanXuat)
                                            </span>
                                        </div>
                                    </td>
                                    <td>
                                        <a href="/PhieuNhap/Details/@item.MaPhieuNhap" class="text-decoration-none text-dark fw-medium bg-light px-2 py-1 rounded">
                                            #PN-@item.MaPhieuNhap?.ToString("D5")
                                        </a>
                                    </td>
                                    <td>
                                        @{
                                            var giaNhap = item.MaPhieuNhapNavigation?.ChiTietPhieuNhap?.FirstOrDefault(ct => ct.MaSanPham == item.MaSanPham)?.DonGiaNhap;
                                        }
                                        @if(giaNhap.HasValue)
                                        {
                                            <span class="fw-bold text-danger">@string.Format("{0:N0}", giaNhap) VNĐ</span>
                                        }
                                    </td>
                                    <td class="text-center align-middle">
                                        @if (item.TrangThai == 1)
                                        {
                                            <span class="badge rounded-pill bg-success bg-opacity-10 text-success px-3 py-2 fw-bold"><i class="fa-solid fa-box me-1 d-print-none"></i> Tồn Kho</span>
                                        }
                                        else if (item.TrangThai == 2)
                                        {
                                            <span class="badge rounded-pill bg-secondary bg-opacity-10 text-secondary px-3 py-2 fw-bold"><i class="fa-solid fa-cart-shopping me-1 d-print-none"></i> Đã Bán</span>
                                        }
                                        else if (item.TrangThai == 3)
                                        {
                                            <span class="badge rounded-pill bg-danger bg-opacity-10 text-danger px-3 py-2 fw-bold"><i class="fa-solid fa-wrench me-1 d-print-none"></i> Lỗi / Bảo Hành</span>
                                        }
                                    </td>
                                    <td class="text-center d-print-none pe-4">
                                        <div class="d-inline-flex gap-1">
                                            <a asp-action="Details" asp-route-id="@item.MaSeri" class="btn btn-sm btn-light border text-info rounded-circle d-inline-flex align-items-center justify-content-center transition" style="width: 32px; height: 32px;" title="Truy Vết">
                                                <i class="fa-solid fa-route"></i>
                                            </a>
                                            <form asp-action="ToggleDefect" asp-route-id="@item.MaSeri" method="post" class="d-inline m-0" onsubmit="return confirm('@(item.TrangThai == 3 ? $"Xác nhận hoàn tất bảo hành / khôi phục: {item.SoSeri}?" : $"Xác nhận báo lỗi cho: {item.SoSeri}?")');">
                                                @if (item.TrangThai == 3)
                                                {
                                                    <button type="submit" class="btn btn-sm btn-light border text-success rounded-circle d-inline-flex align-items-center justify-content-center transition" style="width: 32px; height: 32px;" title="Đã Sửa/Bảo Hành Xong"><i class="fa-solid fa-check"></i></button>
                                                }
                                                else
                                                {
                                                    <button type="submit" class="btn btn-sm btn-light border text-warning rounded-circle d-inline-flex align-items-center justify-content-center transition" style="width: 32px; height: 32px;" title="Báo Lỗi"><i class="fa-solid fa-triangle-exclamation"></i></button>
                                                }
                                            </form>

                                            @if (User.IsInRole("Quản trị viên") || User.IsInRole("Admin") || User.IsInRole("Nhân viên kho"))
                                            {
                                                <a asp-action="Delete" asp-route-id="@item.MaSeri" class="btn btn-sm btn-light border text-danger rounded-circle d-inline-flex align-items-center justify-content-center transition" style="width: 32px; height: 32px;" title="Xoá">
                                                    <i class="fa-solid fa-trash"></i>
                                                </a>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script>
        function validateAndSubmit(element) {
            var fromStr = document.getElementById('fromDateInput').value;
            var toStr = document.getElementById('toDateInput').value;

            if (fromStr && toStr) {
                var f = new Date(fromStr);
                var t = new Date(toStr);

                if (f > t) {
                    Swal.fire({
                        icon: 'error',
                        title: 'Thông tin không hợp lệ',
                        text: 'Ngày bắt đầu không thể lớn hơn ngày kết thúc!',
                        confirmButtonColor: '#0d6efd',
                        confirmButtonText: 'Tôi hiểu'
                    });
                    element.value = '';
                    return;
                }
            }
            element.form.submit();
        }
    </script>
}
