@model IEnumerable<QuanLyKhoLinhKienPC.Models.SeriSanPham>

@{
    ViewData["Title"] = "Quản Lý Kho Seri";
}

<style>
    @@media print {
        /* Ẩn các thành phần của Layout */
        .navbar, .sidebar, .footer { 
            display: none !important; 
        }
        
        /* Trải rộng vùng Content */
        .wrapper, .content {
            margin: 0 !important;
            padding: 0 !important;
            width: 100% !important;
            max-width: 100% !important;
            display: block !important;
        }

        /* Xoá format của trang để in trắng tinh */
        body, html {
            background-color: white !important;
            zoom: 1 !important; /* Bỏ zoom 0.8 của layout */
            height: auto !important;
            overflow: visible !important;
            padding-top: 10mm !important; 
            padding-bottom: 10mm !important;
            padding-left: 15mm !important; 
            padding-right: 15mm !important;
        }

        /* Khắc phục bảng biến mất do absolute/fixed height */
        .h-100, .flex-column, .card:not(.d-print-none), .card-body, .table-responsive {
            height: auto !important;
            display: block !important;
            position: static !important;
            min-height: auto !important;
            overflow: visible !important;
        }
        
        .table-responsive {
            top: auto !important;
            bottom: auto !important;
            left: auto !important;
            right: auto !important;
        }

        /* Xoá bóng râm và viền của thẻ Card */
        .card {
            border: none !important;
            box-shadow: none !important;
        }

        /* Đẩy nội dung in ra trọn trang giấy, giấu tiêu đề phụ do trình duyệt sinh ra (Ngày tháng, URL) */
        @Html.Raw("@page { margin: 0; }")
    }
</style>

<div class="d-flex flex-column h-100">
    <div class="d-flex justify-content-between align-items-center mb-3 flex-shrink-0 d-print-none">
        <h2 class="text-primary m-0"><i class="fa-solid fa-barcode"></i> Quản Lý Kho Seri Linh Kiện</h2>
        @if (User.IsInRole("Quản trị viên") || User.IsInRole("Admin") || User.IsInRole("Nhân viên kho"))
        {
            <div>
                <a asp-action="Trash" class="btn btn-outline-danger shadow-sm" title="Thùng rác">
                    <i class="fa-solid fa-trash-can"></i>
                </a>
            </div>
        }
    </div>

    <!-- TIÊU ĐỀ IN ẤN (Chỉ hiển thị khi in) -->
    <div class="d-none d-print-block text-center mb-4">
        <h2 class="text-uppercase fw-bold">BÁO CÁO THỐNG KÊ KHO SERI</h2>
        <p class="text-muted">
            Ngày in: @DateTime.Now.ToString("dd/MM/yyyy HH:mm") <br/>
            @if(ViewData["FromDate"] != null || ViewData["ToDate"] != null)
            {
                <span>Thời gian: @(ViewData["FromDate"]?.ToString() ?? "...") đến @(ViewData["ToDate"]?.ToString() ?? "...")</span> <br/>
            }
            Trạng thái: 
            @(ViewData["TrangThaiFilter"]?.ToString() == "1" ? "Tồn Kho" : 
              ViewData["TrangThaiFilter"]?.ToString() == "2" ? "Đã Bán" : 
              ViewData["TrangThaiFilter"]?.ToString() == "3" ? "Lỗi/Bảo Hành" : "Tất cả")
        </p>
    </div>

    <div class="flex-shrink-0 d-print-none">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
                <i class="fa-solid fa-check-circle"></i> @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
                <i class="fa-solid fa-circle-exclamation"></i> @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["Warning"] != null)
        {
            <div class="alert alert-warning alert-dismissible fade show shadow-sm" role="alert">
                <i class="fa-solid fa-triangle-exclamation"></i> @TempData["Warning"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
    </div>

    <!-- FILTER BAR -->
    <div class="card mb-3 shadow-sm flex-shrink-0 border-0 d-print-none">
        <div class="card-body py-2">
            <form asp-action="Index" method="get" class="align-items-center">
                <div class="row g-2 mb-2">
                    <div class="col-md-6">
                        <div class="input-group">
                            <span class="input-group-text bg-white text-muted border-end-0"><i class="fa-solid fa-magnifying-glass"></i></span>
                            <input type="text" name="SearchString" class="form-control border-start-0 ps-0" placeholder="Tìm tên linh kiện, mã Seri..." value="@ViewData["CurrentFilter"]">
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="input-group">
                            <span class="input-group-text bg-white text-muted"><i class="fa-solid fa-filter"></i></span>
                            <select name="TrangThaiFilter" class="form-select" onchange="this.form.submit()">
                                <option value="">-- Tất cả trạng thái --</option>
                                <option value="1" selected="@(ViewData["TrangThaiFilter"]?.ToString() == "1")">Tồn Kho (Chưa Bán)</option>
                                <option value="2" selected="@(ViewData["TrangThaiFilter"]?.ToString() == "2")">Đã Bán</option>
                                <option value="3" selected="@(ViewData["TrangThaiFilter"]?.ToString() == "3")">Lỗi/Bảo Hành</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn btn-primary w-100 fw-bold"><i class="fa-solid fa-magnifying-glass"></i> Tìm kiếm</button>
                    </div>
                </div>
                <div class="row g-2">
                    <div class="col-md-4">
                        <div class="input-group">
                            <span class="input-group-text bg-white text-muted">Từ Ngày</span>
                            <input type="date" name="fromDate" id="fromDateInput" class="form-control" value="@ViewData["FromDate"]" onchange="validateAndSubmit(this)">
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="input-group">
                            <span class="input-group-text bg-white text-muted">Đến Ngày</span>
                            <input type="date" name="toDate" id="toDateInput" class="form-control" value="@ViewData["ToDate"]" onchange="validateAndSubmit(this)">
                        </div>
                    </div>
                    <div class="col-md-4">
                        <button type="button" class="btn btn-secondary w-100 fw-bold" onclick="window.print()"><i class="fa-solid fa-print"></i> In Thống Kê</button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- DATA TABLE -->
    <div class="card shadow-sm flex-grow-1 overflow-hidden border-0">
        <div class="card-body p-0 position-relative">
            <div class="table-responsive" style="position: absolute; top: 0; bottom: 0; left: 0; right: 0;">
                <table class="table table-striped table-hover mb-0 w-100 align-middle">
                    <thead class="table-primary">
                        <tr>
                            <th class="py-3 ps-3 text-center" style="width: 5%; position: sticky; top: 0; z-index: 10;">STT</th>
                            <th class="py-3" style="position: sticky; top: 0; z-index: 10;">Mã Số Seri</th>
                            <th class="py-3" style="position: sticky; top: 0; z-index: 10;">Linh Kiện</th>
                            <th class="py-3" style="position: sticky; top: 0; z-index: 10;">Phiếu Nhập</th>
                            <th class="py-3" style="position: sticky; top: 0; z-index: 10;">Giá Nhập</th>
                            <th class="py-3 text-center" style="position: sticky; top: 0; z-index: 10;">Trạng Thái Kho</th>
                            <th class="py-3 text-center d-print-none" style="width: 150px; position: sticky; top: 0; z-index: 10;">Hành Động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted py-5">
                                    <i class="fa-solid fa-barcode fa-3x mb-3 text-secondary opacity-50"></i><br>
                                    Không tìm thấy dữ liệu nào.
                                </td>
                            </tr>
                        }
                        else
                        {
                            int stt = 1;
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="text-center text-muted fw-bold align-middle">@(stt++)</td>
                                    <td class="fw-bold ps-3 align-middle">
                                        @item.SoSeri
                                    </td>
                                    <td class="fw-bold">
                                        <a asp-controller="SanPham" asp-action="Details" asp-route-id="@item.MaSanPham" class="text-decoration-none text-primary" title="Xem chi tiết linh kiện này">
                                            @item.MaSanPhamNavigation?.TenSanPham
                                        </a>
                                        <div class="small text-muted fw-normal mt-1"><i class="fa-solid fa-tag"></i> Hãng: @item.MaSanPhamNavigation?.HangSanXuat</div>
                                    </td>
                                    <td>
                                        <a href="/PhieuNhap/Details/@item.MaPhieuNhap" class="text-decoration-none text-info fw-bold">
                                            <i class="fa-solid fa-receipt"></i> Lô #PN-@item.MaPhieuNhap?.ToString("D5")
                                        </a>
                                    </td>
                                    <td>
                                        @{
                                            var giaNhap = item.MaPhieuNhapNavigation?.ChiTietPhieuNhap?.FirstOrDefault(ct => ct.MaSanPham == item.MaSanPham)?.DonGiaNhap;
                                        }
                                        @if(giaNhap.HasValue)
                                        {
                                            <span class="fw-bold text-danger">@string.Format("{0:N0}", giaNhap) VNĐ</span>
                                        }
                                    </td>
                                    <td class="text-center align-middle">
                                        @if (item.TrangThai == 1)
                                        {
                                            <span class="badge bg-success shadow-sm rounded-pill px-3 py-2"><i class="fa-solid fa-box text-light me-1"></i> Tồn Kho</span>
                                        }
                                        else if (item.TrangThai == 2)
                                        {
                                            <span class="badge bg-secondary shadow-sm rounded-pill px-3 py-2"><i class="fa-solid fa-cart-shopping text-light me-1"></i> Đã Bán</span>
                                        }
                                        else if (item.TrangThai == 3)
                                        {
                                            <span class="badge bg-danger shadow-sm rounded-pill px-3 py-2"><i class="fa-solid fa-wrench text-light me-1"></i> Lỗi/Bảo Hành</span>
                                        }
                                    </td>
                                    <td class="text-center d-print-none">
                                        <div class="d-flex justify-content-center gap-1">
                                            <a asp-action="Details" asp-route-id="@item.MaSeri" class="btn btn-sm btn-info text-white shadow-sm" title="Truy Vết">
                                                <i class="fa-solid fa-route"></i>
                                            </a>
                                            <form asp-action="ToggleDefect" asp-route-id="@item.MaSeri" method="post" class="d-inline m-0" onsubmit="return confirm('@(item.TrangThai == 3 ? $"Xác nhận hoàn tất bảo hành / khôi phục: {item.SoSeri}?" : $"Xác nhận báo lỗi cho: {item.SoSeri}?")');">
                                                @if (item.TrangThai == 3)
                                                {
                                                    <button type="submit" class="btn btn-sm btn-success shadow-sm" title="Đã Sửa/Bảo Hành Xong"><i class="fa-solid fa-wrench"></i></button>
                                                }
                                                else
                                                {
                                                    <button type="submit" class="btn btn-sm btn-outline-danger shadow-sm" title="Báo Lỗi"><i class="fa-solid fa-triangle-exclamation"></i></button>
                                                }
                                            </form>

                                            @if (User.IsInRole("Quản trị viên") || User.IsInRole("Admin") || User.IsInRole("Nhân viên kho"))
                                            {
                                                <a asp-action="Delete" asp-route-id="@item.MaSeri" class="btn btn-sm btn-danger shadow-sm" title="Xoá">
                                                    <i class="fa-solid fa-trash"></i>
                                                </a>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function validateAndSubmit(element) {
            var fromStr = document.getElementById('fromDateInput').value;
            var toStr = document.getElementById('toDateInput').value;

            if (fromStr && toStr) {
                var f = new Date(fromStr);
                var t = new Date(toStr);

                if (f > t) {
                    Swal.fire({
                        icon: 'error',
                        title: 'Thông tin không hợp lệ',
                        text: 'Ngày bắt đầu không thể lớn hơn ngày kết thúc!'
                    });
                    
                    // Reset lại ô bị sai
                    element.value = '';
                    
                    // Không submit form nếu đang lỗi thiết lập
                    return;
                }
            }
            
            // Nếu không lỗi, submit bình thường
            element.form.submit();
        }
    </script>
}
