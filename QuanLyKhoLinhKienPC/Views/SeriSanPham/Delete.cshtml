@model QuanLyKhoLinhKienPC.Models.SeriSanPham

@{
    ViewData["Title"] = "Xóa Seri Sản Phẩm";
}

<div class="container-fluid pt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow rounded-4 border-0" style="box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.05) !important;">
                <div class="card-header bg-white border-bottom border-light py-3">
                    <h4 class="mb-0 text-danger fw-bold"><i class="fa-solid fa-triangle-exclamation me-1"></i> Xóa Seri Sản Phẩm</h4>
                </div>
                <div class="card-body text-center p-4">
                    <h5 class="card-title text-danger mb-4">Bạn có chắc muốn chuyển Seri này vào thùng rác?</h5>

                    <p class="text-muted small mb-4">
                         <i class="fa-solid fa-circle-info"></i> Lưu ý: Dữ liệu sẽ được chuyển vào Thùng rác (có thể khôi phục lại khi cần).
                    </p>

                    <div class="bg-danger bg-opacity-10 py-4 rounded-4 mx-2 text-start shadow-inner border border-danger border-opacity-10">
                        <div class="row px-4 align-items-center g-3 pb-2">
                            <div class="col-sm-4 text-danger fw-semibold">Mã Số Seri:</div>
                            <div class="col-sm-8 fw-bold text-dark fs-5">#@Model.SoSeri</div>
                            
                            <div class="col-sm-4 text-danger fw-semibold">Sản Phẩm:</div>
                            <div class="col-sm-8 text-dark">@Model.MaSanPhamNavigation?.TenSanPham</div>

                            <div class="col-sm-4 text-danger fw-semibold">Phiếu Nhập:</div>
                            <div class="col-sm-8 text-dark">
                                @if(Model.MaPhieuNhapNavigation != null)
                                {
                                    <text>#PN-@Model.MaPhieuNhap.Value.ToString("D5") (@Model.MaPhieuNhapNavigation.NgayNhap.ToString("dd/MM/yyyy"))</text>
                                }
                                else
                                {
                                    <text>N/A</text>
                                }
                            </div>
                            
                            <div class="col-sm-4 text-danger fw-semibold">Giá Nhập:</div>
                            <div class="col-sm-8 text-dark">
                                @{
                                    decimal donGiaNhap = ViewBag.DonGiaNhap != null ? (decimal)ViewBag.DonGiaNhap : 0;
                                }
                                @donGiaNhap.ToString("N0") VNĐ
                            </div>

                            <div class="col-sm-4 text-danger fw-semibold">Trạng Thái:</div>
                            <div class="col-sm-8">
                                @if (Model.TrangThai == 1)
                                {
                                    <span class="badge rounded-pill bg-success px-2 py-1">Tồn Kho</span>
                                }
                                else if (Model.TrangThai == 2)
                                {
                                    <span class="badge rounded-pill bg-secondary px-2 py-1">Đã Bán</span>
                                }
                                else if (Model.TrangThai == 3)
                                {
                                    <span class="badge rounded-pill bg-danger px-2 py-1">Lỗi/Bảo Hành</span>
                                }
                            </div>
                        </div>
                    </div>

                    <form asp-action="Delete" class="mt-5 d-flex justify-content-between px-2">
                        <input type="hidden" asp-for="MaSeri" />
                        <a asp-action="Index" class="btn btn-light border shadow-sm rounded-pill px-4 text-secondary fw-semibold transition">
                            <i class="fa-solid fa-xmark me-1"></i> Hủy bỏ
                        </a>
                        <button type="submit" class="btn btn-danger shadow rounded-pill px-5 fw-bold transition">
                            <i class="fa-solid fa-trash me-1"></i> Đồng ý xóa
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
