@{
    ViewData["Title"] = "Từ Chối Truy Cập";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <h1 class="display-1 text-warning"><i class="fa-solid fa-triangle-exclamation"></i></h1>
            <h2 class="mt-4 mb-3 text-danger">403 - TỪ CHỐI TRUY CẬP</h2>
            
            <div class="alert alert-warning shadow-sm border-0 mb-4 text-start">
                <h5 class="alert-heading"><i class="fa-solid fa-ban"></i> Cảnh báo Quyền Hạn</h5>
                <hr>
                <p class="mb-0">Tài khoản của bạn <strong>(@User.Identity?.Name)</strong> không có đủ đặc quyền (Role) để truy cập vào tính năng này. Vui lòng liên hệ Quản trị viên nếu đây là sự nhầm lẫn.</p>
            </div>

            <div class="d-flex justify-content-center gap-3">
                <a href="javascript:history.back()" class="btn btn-outline-secondary">
                    <i class="fa-solid fa-arrow-left"></i> Quay lại trang trước
                </a>
                <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
                    <i class="fa-solid fa-house"></i> Về Trang chủ
                </a>
            </div>
        </div>
    </div>
</div>
