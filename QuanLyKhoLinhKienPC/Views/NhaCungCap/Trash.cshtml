@model IEnumerable<QuanLyKhoLinhKienPC.Models.NhaCungCap>

@{
    ViewData["Title"] = "Thùng Rác Nhà Cung Cấp";
}

<div class="d-flex flex-column h-100">

    <div class="d-flex justify-content-between align-items-center mb-3 flex-shrink-0">
        <h2 class="text-danger m-0"><i class="fa-solid fa-trash-can"></i> Thùng Rác Nhà Cung Cấp</h2>
        <div>
            @if (Model != null && Model.Any() && (User.IsInRole("Quản trị viên") || User.IsInRole("Admin")))
            {

            }
            <a asp-action="Index" class="btn btn-secondary shadow-sm me-2">
                <i class="fa-solid fa-arrow-left"></i> Quay lại
            </a>
        </div>
    </div>


    <div class="card mb-3 shadow-sm flex-shrink-0 border-0">
        <div class="card-body py-2">
            <form asp-action="Trash" method="get" class="row g-2 align-items-center">
                <div class="col-md-10">
                    <div class="input-group">
                        <span class="input-group-text bg-white text-muted border-end-0"><i class="fa-solid fa-magnifying-glass"></i></span>
                        <input type="text" name="searchString" class="form-control border-start-0 ps-0" placeholder="Tìm kiếm tên, SĐT nhà cung cấp..." value="@ViewData["CurrentFilter"]">
                    </div>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-danger w-100 fw-bold">Tìm kiếm</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm flex-grow-1 overflow-hidden border-0">
        <div class="card-body p-0 position-relative">
            <div class="table-responsive" style="position: absolute; top: 0; bottom: 0; left: 0; right: 0;">
                <table class="table table-striped table-hover mb-0 w-100 align-middle">
                    <thead class="table-danger">
                        <tr>
                            <th class="py-3 ps-3" style="position: sticky; top: 0; z-index: 10;">
                                Tên nhà cung cấp
                            </th>
                            <th class="py-3" style="position: sticky; top: 0; z-index: 10;">
                                Số điện thoại
                            </th>
                            <th class="py-3" style="position: sticky; top: 0; z-index: 10;">
                                Địa chỉ
                            </th>
                            <th class="text-center py-3" style="width: 150px; position: sticky; top: 0; z-index: 10;">
                                Hành động
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="fw-bold ps-3">@Html.DisplayFor(modelItem => item.TenNhaCungCap)</td>
                                    <td>@Html.DisplayFor(modelItem => item.SoDienThoai)</td>
                                    <td class="text-truncate" style="max-width: 300px;">@Html.DisplayFor(modelItem => item.DiaChi)</td>
                                    <td class="text-center py-2">
                                        <form asp-action="Restore" asp-route-id="@item.MaNhaCungCap" method="post" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-success" title="Khôi phục">
                                                <i class="fa-solid fa-rotate-left"></i>
                                            </button>
                                        </form>

                                        @if (User.IsInRole("Quản trị viên") || User.IsInRole("Admin"))
                                        {

                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted py-5">
                                    <i class="fa-regular fa-trash-can fa-3x mb-3 text-secondary opacity-50"></i><br>
                                    Thùng rác trống.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>